---
import '../styles/global.css';
import Button from '../components/Button.astro';
import { APP_STORE_URL, COMPANY_NAME, isAppStoreUrlKnown, SITE_NAME, SUPPORT_EMAIL } from '../lib/site';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import { languages } from '../i18n/ui';

export interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	noindex?: boolean;
	/** Which locales this page is available in. Defaults to all locales. */
	availableLocales?: string[];
}

const { title, description, canonicalPath, noindex = false, availableLocales } = Astro.props;
const localesForHreflang = availableLocales ?? Object.keys(languages);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const pageTitle = title ? `${title} | ${SITE_NAME}` : `${SITE_NAME} — Snus & Nicotine Pouch Reduction App`;
const pageDescription =
	description ??
	'Reduce snus and nicotine pouches gradually with a calm, private app. Track daily allowance, log use in one tap, handle cravings, and see progress over time.';

const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site).toString();
// PNG (not SVG) — most social platforms reject SVG og:image
// Regenerate via: cd website && node -e "require('sharp')(require('fs').readFileSync('public/og-image.svg'),{density:200}).resize(1200,630,{fit:'contain',background:'#000'}).png({compressionLevel:9}).toFile('public/og-image.png')"
const ogImageUrl = new URL('/og-image.png', Astro.site).toString();

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? t('cta.appstore') : t('cta.comingsoon');

const structuredData: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'MobileApplication',
	name: SITE_NAME,
	operatingSystem: 'iOS',
	applicationCategory: 'HealthApplication',
	description: 'A calm, private app for reducing snus and nicotine pouches gradually with daily tracking, craving support tools, and weekly progress.',
	url: new URL('/', Astro.site).toString(),
	offers: { '@type': 'Offer', price: '29', priceCurrency: 'DKK' },
	...(appStoreKnown ? { downloadUrl: APP_STORE_URL, installUrl: APP_STORE_URL } : {}),
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonicalUrl} />
		
		{localesForHreflang.map((abbr) => (
			<link
				rel="alternate"
				hreflang={abbr}
				href={new URL(translatePath(Astro.url.pathname, abbr as keyof typeof languages), Astro.site).toString()}
			/>
		))}
		{localesForHreflang.includes('en') && (
			<link
				rel="alternate"
				hreflang="x-default"
				href={new URL(translatePath(Astro.url.pathname, 'en'), Astro.site).toString()}
			/>
		)}

		{noindex ? (
			<meta name="robots" content="noindex,nofollow" />
		) : (
			<meta name="robots" content="index,follow" />
		)}

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={`${SITE_NAME} — reduce snus and nicotine pouches step by step`} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={`${SITE_NAME} — reduce snus and nicotine pouches step by step`} />

		<meta name="apple-itunes-app" content="app-id=6758867485" />
		<meta name="generator" content={Astro.generator} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

		<!-- Umami Analytics (privacy-friendly, cookie-free) -->
		<script defer src="https://umami-iamjarl.vercel.app/script.js" data-website-id="ab39d27c-ff32-49c4-b9e3-4c8407aad2b8"></script>

		<!-- Premium Typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700;800&display=swap" rel="stylesheet">

		<!-- Scroll Reveal Script -->
		<script is:inline>
			function handleReveal() {
				const reveals = document.querySelectorAll('.reveal');
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
						}
					});
				}, { threshold: 0.1 });
				
				reveals.forEach(reveal => observer.observe(reveal));
			}

			// Run on initial load
			document.addEventListener('DOMContentLoaded', handleReveal);
			// Run on Astro page navigation if applicable
			document.addEventListener('astro:page-load', handleReveal);
		</script>
	</head>

	<body>
		<a class="skip-link" href="#main">Skip to content</a>

		<header class="site-header">
			<div class="container site-header__inner">
				<a class="brand" href={translatePath('/')} aria-label={`${SITE_NAME} home`}>
					<span class="brand__dot" aria-hidden="true"></span>
					<span class="brand__name">{SITE_NAME}</span>
				</a>

				<button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
					<span class="nav-toggle__bar"></span>
					<span class="nav-toggle__bar"></span>
					<span class="nav-toggle__bar"></span>
				</button>

				<nav class="nav" aria-label="Primary">
					<a class="nav__link" href={translatePath('/privacy')}>{t('nav.privacy')}</a>
					<a class="nav__link" href={translatePath('/support')}>{t('nav.support')}</a>
					<Button
						variant="primary"
						href={APP_STORE_URL}
						disabled={!appStoreKnown}
						external={true}
						ariaLabel={appStoreCtaLabel}
						trackSource="header"
					>
						{appStoreCtaLabel}
					</Button>
				</nav>
			</div>
		</header>

		<script is:inline>
			const toggle = document.querySelector('.nav-toggle');
			const nav = document.querySelector('.nav');
			if (toggle && nav) {
				toggle.addEventListener('click', () => {
					const open = nav.classList.toggle('nav--open');
					toggle.classList.toggle('nav-toggle--open', open);
					toggle.setAttribute('aria-expanded', String(open));
				});
				nav.querySelectorAll('a').forEach(link => {
					link.addEventListener('click', () => {
						nav.classList.remove('nav--open');
						toggle.classList.remove('nav-toggle--open');
						toggle.setAttribute('aria-expanded', 'false');
					});
				});
			}
		</script>

		<main id="main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container site-footer__grid">
				<div class="site-footer__col">
					<p class="footer-heading">{SITE_NAME}</p>
					<a href={translatePath('/privacy')}>{t('nav.privacy')}</a>
					<a href={translatePath('/support')}>{t('nav.support')}</a>
					{appStoreKnown ? (
						<a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer">App Store</a>
					) : (
						<span class="disabled-link" aria-disabled="true">App Store</span>
					)}
				</div>
				<div class="site-footer__col">
					<p class="footer-heading">Resources</p>
					<a href="/snus-reduction-app/">Snus Reduction App</a>
					<a href="/nicotine-pouch-reduction-app/">Nicotine Pouch Reduction</a>
					<a href="/how-to-reduce-snus/">How to Reduce Snus</a>
					<a href="/how-to-quit-nicotine-pouches/">How to Quit Nicotine Pouches</a>
					<a href="/wean-vs-habit-tracker/">Wean vs. Habit Tracker</a>
				</div>
				<div class="site-footer__col">
					<p class="footer-heading">Guides</p>
					<a href="/how-to-handle-nicotine-cravings/">Handle Nicotine Cravings</a>
					<a href="/taper-nicotine/">Taper Nicotine</a>
					<a href="/gradual-reduction-vs-cold-turkey/">Gradual vs. Cold Turkey</a>
					<a href="/track-snus-use/">Track Snus Use</a>
					<a href="/private-quit-nicotine-app/">Private Quit App</a>
				</div>
				<div class="site-footer__col">
					<p class="footer-heading">More from IAMJARL</p>
					<a href="https://iamjarl.com" target="_blank" rel="noopener noreferrer">IAMJARL Portfolio</a>
					<a href="https://wodrounds.iamjarl.com" target="_blank" rel="noopener noreferrer">WODrounds</a>
					<a href="https://madebyhuman.iamjarl.com" target="_blank" rel="noopener noreferrer">Made by Human</a>
				</div>
			</div>
			<div class="container site-footer__bottom">
				<p class="fineprint">
					© {new Date().getFullYear()} <a href="https://iamjarl.com" target="_blank" rel="noopener noreferrer">{COMPANY_NAME}</a>. All rights reserved. {t('footer.tagline')}
				</p>
				<p class="fineprint"><a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a></p>
			</div>
		</footer>
	</body>
</html>

<style>
	.skip-link {
		position: absolute;
		left: -9999px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}
	.skip-link:focus {
		position: fixed;
		top: var(--space-sm);
		left: var(--space-sm);
		width: auto;
		height: auto;
		padding: var(--space-sm) var(--space-md);
		background: var(--bg-app);
		color: var(--primary);
		border: 1px solid var(--primary);
		border-radius: var(--radius-md);
		z-index: 100;
		font-weight: 600;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: linear-gradient(
			to bottom,
			color-mix(in oklab, var(--bg-app), transparent 10%),
			color-mix(in oklab, var(--bg-app), transparent 25%)
		);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		border-bottom: 1px solid color-mix(in oklab, var(--border-subtle), transparent 40%);
		box-shadow: 0 4px 24px color-mix(in oklab, #000000, transparent 97%);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-lg);
		padding-top: var(--space-lg);
		padding-bottom: var(--space-lg);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}

	.brand__dot {
		width: 12px;
		height: 12px;
		border-radius: 9999px;
		background: var(--primary);
		box-shadow: 0 0 0 6px color-mix(in oklab, var(--primary), transparent 75%);
	}

	.brand__name {
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.nav-toggle {
		display: none;
		background: none;
		border: none;
		padding: var(--space-sm);
		cursor: pointer;
		flex-direction: column;
		gap: 5px;
		z-index: 60;
	}

	.nav-toggle__bar {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--text-primary);
		border-radius: 2px;
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	.nav-toggle--open .nav-toggle__bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.nav-toggle--open .nav-toggle__bar:nth-child(2) {
		opacity: 0;
	}
	.nav-toggle--open .nav-toggle__bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.nav {
		display: flex;
		align-items: center;
		gap: var(--space-lg);
	}

	.nav__link {
		color: var(--text-secondary);
		font-weight: 600;
	}

	.nav__link:hover {
		color: var(--text-primary);
		text-decoration: none;
	}

	@media (max-width: 700px) {
		.nav-toggle {
			display: flex;
		}

		.nav {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			background: var(--bg-app);
			border-bottom: 1px solid var(--border-subtle);
			box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
			padding: var(--space-sm) var(--space-xl);
		}

		.nav--open {
			display: flex;
		}

		.nav__link {
			padding: var(--space-md) 0;
			border-bottom: 1px solid var(--border-subtle);
		}

		.nav :global(.btn) {
			margin-top: var(--space-md);
			margin-bottom: var(--space-md);
			text-align: center;
		}
	}

	main {
		min-height: calc(100vh - 120px);
	}

	.site-footer {
		border-top: 1px solid var(--border-subtle);
		padding: var(--space-huge) 0 var(--space-xxl);
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-xxl);
		padding-bottom: var(--space-xxl);
		border-bottom: 1px solid var(--border-subtle);
		margin-bottom: var(--space-xl);
	}

	.site-footer__col {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.site-footer__col a {
		color: var(--text-secondary);
		font-size: var(--font-size-sm);
	}

	.site-footer__col a:hover {
		color: var(--text-primary);
		text-decoration: none;
	}

	.footer-heading {
		margin: 0 0 var(--space-sm);
		font-weight: 700;
		font-size: var(--font-size-sm);
		color: var(--text-primary);
	}

	.site-footer__bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-lg);
	}

	.fineprint {
		margin: 0;
		color: var(--text-tertiary);
		font-size: 13px;
	}

	.fineprint a {
		color: var(--text-tertiary);
	}

	.fineprint a:hover {
		color: var(--text-primary);
	}

	.disabled-link {
		color: var(--text-tertiary);
		font-size: var(--font-size-sm);
	}

	@media (max-width: 900px) {
		.site-footer__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 700px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.site-footer__col {
			align-items: center;
		}

		.site-footer__bottom {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
