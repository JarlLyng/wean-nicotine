---
type Variant = 'primary' | 'secondary' | 'ghost';

export interface Props {
	href?: string;
	variant?: Variant;
	disabled?: boolean;
	external?: boolean;
	ariaLabel?: string;
	/** Umami event name. If set, clicks are tracked. */
	trackEvent?: string;
	/** Optional source identifier (e.g. "hero", "footer") sent with the event. */
	trackSource?: string;
}

const {
	href,
	variant = 'primary',
	disabled = false,
	external = false,
	ariaLabel,
	trackEvent,
	trackSource,
} = Astro.props;

const target = external ? '_blank' : undefined;
const rel = external ? 'noopener noreferrer' : undefined;
const isAppStoreLink = typeof href === 'string' && href.includes('apps.apple.com');
const resolvedEvent = trackEvent ?? (isAppStoreLink ? 'app-store-click' : undefined);
---

<a
	class:list={['btn', `btn--${variant}`, disabled && 'is-disabled']}
	href={disabled ? undefined : href}
	target={disabled ? undefined : target}
	rel={disabled ? undefined : rel}
	aria-disabled={disabled ? 'true' : undefined}
	aria-label={ariaLabel}
	tabindex={disabled ? -1 : undefined}
	data-umami-event={resolvedEvent}
	data-umami-event-source={resolvedEvent ? (trackSource ?? 'button') : undefined}
>
	<slot />
</a>

<style>
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 14px 28px;
		border-radius: var(--radius-xl);
		font-family: var(--font-display);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-bold);
		letter-spacing: -0.01em;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		cursor: pointer;
		white-space: nowrap;
	}

	.btn:active {
		transform: scale(0.96);
	}

	.btn--primary {
		background: var(--primary);
		color: var(--on-primary);
		border: 1px solid color-mix(in oklab, var(--primary), white 20%);
		box-shadow: 0 10px 30px color-mix(in oklab, var(--primary), transparent 80%);
	}

	.btn--primary:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 40px color-mix(in oklab, var(--primary), transparent 70%);
		background: color-mix(in oklab, var(--primary), white 10%);
	}

	.btn--secondary {
		background: var(--glass-bg);
		backdrop-filter: blur(var(--glass-blur));
		-webkit-backdrop-filter: blur(var(--glass-blur));
		color: var(--text-primary);
		border: 1px solid var(--glass-border);
		box-shadow: var(--shadow-premium);
	}

	.btn--secondary:hover {
		transform: translateY(-4px);
		background: color-mix(in oklab, var(--glass-bg), white 20%);
		border-color: color-mix(in oklab, var(--primary), transparent 50%);
	}

	.btn--ghost {
		background: transparent;
		color: var(--text-secondary);
		border: 1px solid transparent;
	}

	.btn--ghost:hover {
		background: var(--bg-muted);
		color: var(--text-primary);
	}

	.is-disabled {
		opacity: 0.5;
		cursor: not-allowed;
		pointer-events: none;
	}
</style>

