---
import NordicHome, { type NordicHomeContent } from '../../components/NordicHome.astro';
import { SITE_NAME } from '../../lib/site';

const content: NordicHomeContent = {
	meta: {
		title: 'Nedtrapning af Snus & Nikotinposer App',
		description:
			'Skær gradvist ned for snus og nikotinposer med en rolig, privat app. Følg din daglige kvote, registrer forbrug med ét tryk, og få støtte, når trangen melder sig.',
	},
	hero: {
		kicker: 'Rolig. Privat. Ingen skam.',
		heading: 'Skridt for skridt mod en nikotinfri hverdag.',
		subline: `${SITE_NAME} er en rolig og privat app, der hjælper dig med at trappe ned for snus og nikotinposer i dit eget tempo — uden løftede pegefingre.`,
		ctaKnown: 'Hent i App Store',
		ctaUnknown: 'Kommer snart i App Store',
		privacyLabel: 'Se privatlivspolitik',
		fineprint: 'Ingen konto · Ingen brugssporing · Ingen abonnement · Dine data bliver på din enhed',
		imageAlt: 'Wean Nicotine app, der viser det daglige kvoteoverblik',
	},
	how: {
		title: 'Sådan trapper du ned for snus eller nikotinposer gradvist',
		lede: 'En enkel, rolig proces, du kan holde fast i.',
		steps: [
			{
				title: '1) Sæt dit udgangspunkt',
				text: 'Fortæl Wean, hvor mange nikotinposer du bruger om dagen. Tilføj eventuelt pris pr. dåse.',
			},
			{
				title: '2) Følg din daglige kvote',
				text: "Få et tydeligt dagligt tal og tjek ind med ét tryk: 'Brugte en pose' eller 'Modstod trang'.",
			},
			{
				title: '3) Følg fremskridt + brug værktøjer',
				text: 'Se ugentlige fremskridt, og brug vejrtrækningsøvelser samt refleksionsværktøjer bedst muligt.',
			},
		],
	},
	features: {
		title: 'Værktøjer der gør en forskel',
		lede: 'Alt hvad du behøver for at skære gradvist ned – uden konti, skam eller støj.',
		cards: [
			{
				title: 'Interaktiv vejrtrækning',
				text: 'Berolig dit nervesystem med 4-7-8, Box Breathing eller Quick Calm vibrationer.',
			},
			{
				title: 'Guidet Urge Surfing',
				text: "En 5-minutters guidet timer der hjælper dig med at observere og 'ride' på nikotintrangen.",
			},
			{
				title: 'Refleksions-journal',
				text: 'Gem korte noter om dine triggere og fremskridt for at forstå dit mønster bedre.',
			},
			{
				title: 'Økonomisk overblik',
				text: 'Se præcis hvor mange penge du har sparet i din lokale valuta siden du startede.',
			},
			{
				title: 'Privatliv som standard',
				text: 'Ingen konti, ingen skysynkronisering, ingen brugssporing. Dine logs og plan bliver på din enhed.',
			},
			{
				title: 'Ingen abonnement',
				text: 'Betal én gang, ej appen for evigt. Ingen skjulte gebyrer eller tilbagevendende betalinger.',
			},
		],
	},
	faq: {
		title: 'Ofte stillede spørgsmål',
		lede: 'Typiske spørgsmål om nedtrapning og sporing af snus og nikotinposer.',
		items: [
			{
				question: 'Hvordan hjælper Wean Nicotine mig med at skære ned på snus?',
				answer:
					'Wean Nicotine skaber en gradvis nedtrapningsplan baseret på dit nuværende daglige forbrug. Hver uge sænkes din daglige kvote en smule, så du skærer ned skridt for skridt i stedet for den kolde tyrker.',
			},
			{
				question: 'Fungerer Wean Nicotine også for nikotinposer?',
				answer:
					'Ja. Wean Nicotine fungerer både for snus og nikotinposer. Nedtrapningsmetoden er den samme uanset, hvilket produkt du bruger.',
			},
			{
				question: 'Er dette medicinsk rådgivning?',
				answer:
					'Nej. Wean Nicotine er et selvhjælpsredskab til sporing og gradvis nikotinnedtrapning. Det yder ikke medicinsk rådgivning eller klinisk behandling.',
			},
			{
				question: 'Hvor er mine data gemt?',
				answer:
					'Alle data forbliver på din enhed. Wean Nicotine kræver ikke en konto og synkroniserer ikke til skyen.',
			},
			{
				question: 'Kan jeg slette alt?',
				answer:
					'Ja. Brug "Start forfra" i appen til at slette alle lokale data, eller slet blot appen.',
			},
			{
				question: 'Fungerer Wean Nicotine offline?',
				answer:
					'Ja. Da Wean Nicotine gemmer lokalt først, fungerer alle core features uden internetforbindelse.',
			},
			{
				question: 'Kan jeg spore nikotinposer uden at oprette en konto?',
				answer:
					'Ja. Wean Nicotine kræver ingen konto, intet login og ingen tilmelding. Du kan begynde med det samme.',
			},
			{
				question: 'Hvad koster Wean Nicotine?',
				answer:
					'Wean Nicotine er et engangskøb — ingen abonnementer, ingen reklamer og ingen salg af data. Du betaler én gang og får alle funktioner, bygget af en uafhængig soloudvikler.',
			},
		],
	},
};
---

<NordicHome lang="da" bgImage="/images/unsplash/nordic-1.jpg" content={content} />
