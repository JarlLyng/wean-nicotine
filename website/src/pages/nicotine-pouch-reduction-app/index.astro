---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Download on the App Store' : 'Coming soon on the App Store';
---

<Layout
	title="Nicotine Pouch Reduction App — Track and Cut Down"
	description="Taper helps you reduce nicotine pouches gradually with simple daily tracking, progress over time, and a calm, private experience."
	canonicalPath="/nicotine-pouch-reduction-app/"
>
	<section class="hero">
		<div class="container">
			<h1>Nicotine pouch reduction app — track and cut down</h1>
			<p class="lede">
				Taper helps you reduce your nicotine pouch use gradually. Set a daily allowance, track each pouch with one tap,
				and watch your usage decrease week by week.
			</p>
			<div class="cta">
				<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
					{appStoreCtaLabel}
				</Button>
				<Button variant="secondary" href="/">Learn more about Taper</Button>
			</div>
		</div>
	</section>

	<Section id="who" title="Who this is for" lede="People who use nicotine pouches and want to cut down without quitting cold turkey.">
		<div class="grid-2">
			<Card as="article">
				<h3>You want to use fewer nicotine pouches per day</h3>
				<p>Whether your goal is to reduce from 15 to 5 or from 8 to zero, Taper gives you a plan that decreases gradually.</p>
			</Card>
			<Card as="article">
				<h3>You want a clear daily number to follow</h3>
				<p>Instead of vague goals, Taper gives you a specific number of pouches each day. Tap once when you use one.</p>
			</Card>
			<Card as="article">
				<h3>You want to handle cravings better</h3>
				<p>Built-in breathing exercises, urge surfing, and reflection prompts help you manage the moments when you want to reach for a pouch.</p>
			</Card>
			<Card as="article">
				<h3>You want privacy</h3>
				<p>No accounts, no cloud, no data sharing. Your nicotine pouch tracking stays entirely on your device.</p>
			</Card>
		</div>
	</Section>

	<Section id="how" title="How to reduce nicotine pouches with Taper" lede="Three steps to start cutting down.">
		<div class="grid-3">
			<Card as="article">
				<h3>1) Enter your current usage</h3>
				<p>Tell Taper how many nicotine pouches you use per day. This becomes your starting allowance.</p>
			</Card>
			<Card as="article">
				<h3>2) Track daily with one tap</h3>
				<p>Each time you use a pouch, tap once. Each time you resist a craving, tap once. That is all you need to do.</p>
			</Card>
			<Card as="article">
				<h3>3) Watch your usage decrease</h3>
				<p>Your daily allowance drops each week. Track your progress with weekly trends, totals, and optional money saved.</p>
			</Card>
		</div>
	</Section>

	<Section id="why" title="Why choose Taper over a generic habit tracker" lede="Taper is built specifically for nicotine pouch reduction.">
		<div class="grid-2">
			<Card as="article">
				<h3>Tapering plan, not streaks</h3>
				<p>Generic trackers count habits. Taper gives you a decreasing daily allowance designed for gradual nicotine reduction.</p>
			</Card>
			<Card as="article">
				<h3>Craving tools built in</h3>
				<p>Breathing exercises and urge surfing are available right when you need them, not in a separate app.</p>
			</Card>
			<Card as="article">
				<h3>No judgment</h3>
				<p>If you go over your allowance, Taper keeps going. The approach is calm and supportive, not punishing.</p>
			</Card>
			<Card as="article">
				<h3>Completely private</h3>
				<p>No accounts, no login, no cloud sync. Your nicotine pouch data never leaves your device.</p>
			</Card>
		</div>
	</Section>

	<Section id="faq" title="Frequently asked questions about nicotine pouch reduction">
		<div class="grid-2">
			<Card as="article">
				<h3>Does Taper work for all nicotine pouch brands?</h3>
				<p>Yes. Taper tracks pouch count, not brand or strength. It works with ZYN, VELO, On!, or any other brand.</p>
			</Card>
			<Card as="article">
				<h3>Can I adjust the reduction speed?</h3>
				<p>Yes. You set the weekly reduction percentage during onboarding. You can also start over with different settings at any time.</p>
			</Card>
			<Card as="article">
				<h3>Does Taper work for snus too?</h3>
				<p>Yes. Taper works for both traditional snus and nicotine pouches. The reduction approach is the same.</p>
			</Card>
			<Card as="article">
				<h3>Is Taper free?</h3>
				<p>Yes. Taper is free to download and use.</p>
			</Card>
		</div>
	</Section>

	<section class="bottom-cta">
		<div class="container">
			<h2>Ready to cut down on nicotine pouches?</h2>
			<p>Start tracking today and let Taper reduce your daily allowance week by week.</p>
			<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
				{appStoreCtaLabel}
			</Button>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding: clamp(54px, 7vw, 96px) 0;
		border-bottom: 1px solid var(--border-subtle);
	}

	h1 {
		margin: 0 0 var(--space-lg);
		font-size: clamp(36px, 5vw, 48px);
		line-height: 1.1;
		letter-spacing: -0.03em;
	}

	.lede {
		margin: 0 0 var(--space-xl);
		color: var(--text-secondary);
		max-width: 62ch;
		font-size: 18px;
		line-height: 28px;
	}

	.cta {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	.grid-2, .grid-3 {
		display: grid;
		gap: var(--space-lg);
	}

	.grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	.grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }

	h3 {
		margin: 0 0 var(--space-sm);
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	p { margin: 0; color: var(--text-secondary); }

	.bottom-cta {
		padding: clamp(44px, 6vw, 84px) 0;
		text-align: center;
		border-top: 1px solid var(--border-subtle);
	}

	.bottom-cta h2 {
		margin: 0 0 var(--space-md);
		font-size: clamp(28px, 3.2vw, 36px);
		letter-spacing: -0.02em;
	}

	.bottom-cta p {
		margin: 0 0 var(--space-xl);
		color: var(--text-secondary);
	}

	@media (max-width: 960px) {
		.grid-3 { grid-template-columns: 1fr; }
	}

	@media (max-width: 700px) {
		.grid-2 { grid-template-columns: 1fr; }
	}
</style>
