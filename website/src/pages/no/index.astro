---
import NordicHome, { type NordicHomeContent } from '../../components/NordicHome.astro';
import { SITE_NAME } from '../../lib/site';

const content: NordicHomeContent = {
	meta: {
		title: 'Nedtrapping av Snus & Nikotinposer App',
		description:
			'Trapp gradvis ned på snus og nikotinposer med en rolig, privat app. Følg dagens kvote, logg bruk med ett trykk, og få hjelp med suget.',
	},
	hero: {
		kicker: 'Rolig. Privat. Ingen skam.',
		heading: 'Trapp ned i ditt eget tempo.',
		subline: `${SITE_NAME} er en rolig og privat app som hjelper deg å kutte ned på snus og nikotinposer — helt uten mas eller abonnement.`,
		ctaKnown: 'Last ned i App Store',
		ctaUnknown: 'Kommer snart i App Store',
		privacyLabel: 'Se personvernerklæring',
		fineprint: 'Ingen konto · Ingen bruksporing · Ingen abonnement · Dataene dine blir på enheten',
		imageAlt: 'Wean Nicotine app. Idag skjermen.',
	},
	how: {
		title: 'Slik fungerer det',
		lede: 'En enkel og skånsom prosess du greier å holde deg til.',
		steps: [
			{
				title: '1) Sett et utgangspunkt',
				text: 'Fortell Wean hvor mange poser du bruker per dag og din nåværende pris.',
			},
			{
				title: '2) Følg kvoten',
				text: 'Få et tydelig tall hver dag og logg med ett trykk: "Brukte en" eller "Stod imot".',
			},
			{
				title: '3) Bruk verktøyene',
				text: 'Benytt pusteøvelser, refleksjon og se pengene du sparer hver uke.',
			},
		],
	},
	features: {
		title: 'Viktige verktøy i hverdagen',
		lede: 'Alt du trenger for å kutte ned gradvis — fri for kontoer, skam og mas.',
		cards: [
			{
				title: 'Interaktiv pust',
				text: 'Ro ned nervesystemet med 4-7-8, Box Breathing eller Quick Calm vibrasjoner.',
			},
			{
				title: 'Guidet Urge Surfing',
				text: "En 5-minutters timer som hjelper deg å observere og 'ri ut' suget.",
			},
			{
				title: 'Refleksjons-notater',
				text: 'Lagre korte notater om dine triggere og fremgang for å forstå dine mønstre.',
			},
			{
				title: 'Økonomisk oversikt',
				text: 'Se nøyaktig hvor mye du har spart siden du startet — rett på din iPhone.',
			},
			{
				title: 'Personvern først',
				text: 'Ingen kontoer, ingen skysynkronisering, ingen bruksporing. Loggene og planen din blir på enheten din.',
			},
			{
				title: 'Engangskjøp',
				text: 'Betal én gang, eier appen for alltid. Ingen abonnementer eller skjulte gebyrer.',
			},
		],
	},
	faq: {
		title: 'Vanlige Spørsmål',
		lede: 'Gjentatte spørsmål ved reduksjon og sporing av snus og nikotinposer.',
		items: [
			{
				question: 'Hvordan hjelper Wean Nicotine meg med å kutte ned på snus?',
				answer:
					'Wean Nicotine lager en gradvis nedtrappingsplan basert på ditt nåværende daglige bruk. Hver uke reduseres den daglige kvoten din litt, slik at du kutter ned trinn for trinn i stedet for å utsette deg for bråstopp.',
			},
			{
				question: 'Fungerer Wean Nicotine for nikotinposer også?',
				answer:
					'Ja. Wean Nicotine fungerer både for snus og nikotinposer. Nedtrappingsmetoden er den samme uansett hvilket produkt du bruker.',
			},
			{
				question: 'Er dette medisinsk rådgivning?',
				answer:
					'Nei. Wean Nicotine er et selvhjelpsverktøy for sporing og gradvis nedtrapping. Det gir ikke medisinsk råd eller klinisk behandling.',
			},
			{
				question: 'Hvor lagres dataene mine?',
				answer:
					'Alle data forblir på enheten din. Wean Nicotine krever ikke en konto og synkroniserer ikke med nettskyen.',
			},
			{
				question: 'Kan jeg slette alt?',
				answer:
					'Ja. Bruk "Start forfra" inni appen for å slette alle lokale data, eller slett rett og slett selve appen.',
			},
			{
				question: 'Fungerer Wean Nicotine offline?',
				answer:
					'Ja. Wean Nicotine lagrer lokalt, og krever derfor ingen internettforbindelse for grunnleggende funksjoner.',
			},
			{
				question: 'Kan jeg spore nikotinposer uten å opprette konto?',
				answer:
					'Ja. Wean Nicotine har ingen kontoer, ingen innlogging og ingen registrering. Du kan starte sporingen umiddelbart.',
			},
			{
				question: 'Hva koster Wean Nicotine?',
				answer:
					'Wean Nicotine er et engangskjøp — ingen abonnementer, ingen reklame og ingen salg av data. Du betaler én gang og får alle funksjoner, bygget av en uavhengig soloutvikler.',
			},
		],
	},
};
---

<NordicHome lang="no" bgImage="/images/unsplash/nordic-2.jpg" content={content} />
