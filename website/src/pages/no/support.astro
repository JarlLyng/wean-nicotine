---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import { SUPPORT_EMAIL } from '../../lib/site';
---

<Layout
	title="Support"
	description="Support for Taper iOS-appen."
	canonicalPath="/no/support/"
>
	<Section
		id="support"
		title="Support"
		lede="Trenger du hjelp, eller vil du dele tilbakemeldinger? Vi leser hver e-post."
	>
		<div class="grid">
			<Card as="article">
				<h3>Kontakt</h3>
				<p>
					Send oss en e-post til <a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
				</p>
			</Card>

			<Card as="article">
				<h3>Feilsøking</h3>
				<ul>
					<li>Hvis varsler ikke fungerer, sjekk iOS-varslingstillatelsene for Taper.</li>
					<li>Hvis nedtrappingsplanen din virker for aggressiv, juster dine base-innstillinger i appen.</li>
					<li>For å slette lokale data, bruk "Start på nytt" inne i appen.</li>
				</ul>
			</Card>

			<Card as="article">
				<h3>Personvern</h3>
				<p>
					Dataene lagres på enheten din. Les <a href="/no/privacy">Personvernerklæringen</a>.
				</p>
			</Card>
		</div>
	</Section>
</Layout>

<style>
	.grid {
		display: grid;
		gap: var(--space-lg);
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	h3 {
		margin: 0 0 var(--space-sm);
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	p {
		margin: 0;
		color: var(--text-secondary);
	}

	ul {
		margin: var(--space-sm) 0 0;
		padding-left: 18px;
		color: var(--text-secondary);
	}

	li {
		margin: 6px 0;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
