---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => data.published !== false))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
	title="Blog"
	description="Notes on tapering nicotine pouches, privacy-first health apps, and building Wean Nicotine as a solo indie."
	canonicalPath="/blog/"
	availableLocales={['en']}
>
	<section class="blog-index container">
		<header class="blog-index__header">
			<h1>Blog</h1>
			<p class="blog-index__lede">
				Notes on tapering, harm reduction, privacy-first health apps, and the indie route.
			</p>
			<p class="blog-index__rss">
				<a href="/rss.xml">RSS feed →</a>
			</p>
		</header>

		{posts.length === 0 ? (
			<p class="blog-index__empty">No posts yet. Check back soon.</p>
		) : (
			<ul class="blog-index__list">
				{posts.map((post) => {
					const isoDate = post.data.pubDate.toISOString();
					const niceDate = post.data.pubDate.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					});
					return (
						<li class="blog-card">
							<a href={`/blog/${post.id}/`} class="blog-card__link">
								<time datetime={isoDate}>{niceDate}</time>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								{post.data.tags.length > 0 && (
									<ul class="blog-card__tags">
										{post.data.tags.map((tag) => (
											<li>#{tag}</li>
										))}
									</ul>
								)}
							</a>
						</li>
					);
				})}
			</ul>
		)}
	</section>
</Layout>

<style>
	.blog-index {
		max-width: 880px;
		padding-top: var(--space-xxxl);
		padding-bottom: var(--space-xxxl);
	}
	.blog-index__header {
		margin-bottom: var(--space-xxxl);
	}
	.blog-index__header h1 {
		font-family: var(--font-display);
		font-size: var(--font-size-hero);
		line-height: var(--line-height-tight);
		margin: 0 0 var(--space-md);
	}
	.blog-index__lede {
		font-size: var(--font-size-lg);
		line-height: var(--line-height-relaxed);
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 0 var(--space-md);
	}
	.blog-index__rss a {
		color: var(--primary);
		font-weight: var(--font-weight-semibold);
		text-decoration: none;
	}
	.blog-index__empty {
		color: var(--text-secondary);
	}
	.blog-index__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-xl);
	}
	.blog-card {
		border-bottom: 1px solid var(--border-subtle);
		padding-bottom: var(--space-xl);
	}
	.blog-card:last-child {
		border-bottom: 0;
	}
	.blog-card__link {
		display: grid;
		gap: var(--space-sm);
		color: inherit;
		text-decoration: none;
	}
	.blog-card__link time {
		font-size: var(--font-size-sm);
		color: var(--text-tertiary);
	}
	.blog-card__link h2 {
		font-family: var(--font-display);
		font-size: var(--font-size-xl);
		line-height: var(--line-height-snug);
		margin: 0;
		color: var(--text-primary);
	}
	.blog-card__link p {
		margin: 0;
		color: var(--text-secondary);
		line-height: var(--line-height-relaxed);
	}
	.blog-card__link:hover h2 {
		color: var(--primary);
	}
	.blog-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin: var(--space-xs) 0 0;
		padding: 0;
		list-style: none;
		font-size: var(--font-size-sm);
		color: var(--text-tertiary);
	}
</style>
