---
import SeoLandingLayout from '../../layouts/SeoLandingLayout.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import { APP_STORE_URL, isAppStoreUrlKnown } from '../../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Download on the App Store' : 'Coming soon on the App Store';
---

<SeoLandingLayout
	title="Snus Reduction App — Cut Down Step by Step"
	description="Looking for a snus reduction app? Taper helps you cut down gradually with a daily allowance, one-tap tracking, private progress, and craving support tools."
	canonicalPath="/snus-reduction-app/"
	h1="Snus reduction app — cut down step by step"
	lede="Taper is a calm, private iPhone app built specifically for people who want to reduce their snus use gradually. Instead of quitting cold turkey, you set a daily allowance that decreases week by week."
	bottomCtaHeading="Ready to reduce your snus use?"
	bottomCtaText="Start with your current daily amount and let Taper guide you down step by step."
	appStoreCtaLabel={appStoreCtaLabel}
	campaignToken="seo_en_snus"
	lang="en"
>
	<script type="application/ld+json" slot="after-guide">
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Home",
					"item": "https://taper.iamjarl.com"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Snus Reduction App",
					"item": "https://taper.iamjarl.com/snus-reduction-app/"
				}
			]
		}
	</script>

	<section class="guide__section">
		<h2>Who this is for</h2>
		<p>Taper is designed for people who use snus and want to cut down at their own pace.</p>
		<div class="grid-2">
			<Card as="article">
				<h3>You want to reduce, not necessarily quit overnight</h3>
				<p>Maybe you want to use fewer pouches per day, spend less money, or just feel more in control. Taper supports gradual reduction without pressure.</p>
			</Card>
			<Card as="article">
				<h3>You have tried before but lost track</h3>
				<p>Without a clear daily number it is easy to slip back. Taper gives you a specific allowance each day and tracks whether you stay within it.</p>
			</Card>
			<Card as="article">
				<h3>You prefer privacy over social features</h3>
				<p>Taper has no accounts, no cloud sync, and no sharing. Your progress stays on your device.</p>
			</Card>
			<Card as="article">
				<h3>You want something simple</h3>
				<p>No complicated settings or long onboarding. Tell Taper how many pouches you use, and it creates a weekly reduction plan for you.</p>
			</Card>
		</div>
	</section>

	<section class="guide__section">
		<h2>How Taper helps you reduce snus</h2>
		<p>A straightforward process that works week by week.</p>
		<div class="grid-3">
			<Card as="article">
				<h3>1) Set your baseline</h3>
				<p>Tell Taper how many snus pouches you use per day. This becomes your starting point.</p>
			</Card>
			<Card as="article">
				<h3>2) Follow your daily allowance</h3>
				<p>Each day you get a clear number. Log each pouch with one tap. The allowance decreases gradually each week.</p>
			</Card>
			<Card as="article">
				<h3>3) Track progress and handle cravings</h3>
				<p>See weekly trends, total pouches avoided, and optional money saved. Use breathing and urge surfing tools when cravings hit.</p>
			</Card>
		</div>
	</section>

	<section class="guide__section">
		<h2>Why a dedicated snus reduction app</h2>
		<p>Generic habit trackers are not built for nicotine reduction.</p>
		<div class="grid-2">
			<Card as="article">
				<h3>Built around daily allowance</h3>
				<p>Most habit trackers count streaks or habits. Taper gives you a specific number of pouches per day and adjusts it over time.</p>
			</Card>
			<Card as="article">
				<h3>Craving support tools included</h3>
				<p>Breathing exercises, urge surfing, and reflection prompts are built in for the moments when you want to reach for a pouch.</p>
			</Card>
			<Card as="article">
				<h3>No accounts or cloud sync</h3>
				<p>Your snus tracking data stays on your device. No sign-up, no login, no data leaving your phone.</p>
			</Card>
			<Card as="article">
				<h3>Works offline</h3>
				<p>Because everything is stored locally, Taper works without an internet connection.</p>
			</Card>
		</div>
	</section>

	<Section id="faq" title="Frequently asked questions about snus reduction" slot="after-guide">
		<div class="grid-2">
			<Card as="article">
				<h3>How fast does Taper reduce my snus allowance?</h3>
				<p>You choose the pace. Taper decreases your daily allowance by a percentage each week that you set during onboarding.</p>
			</Card>
			<Card as="article">
				<h3>Can I track the cost of my snus use?</h3>
				<p>Yes. Optionally enter the price per can and Taper calculates how much money you have saved over time.</p>
			</Card>
			<Card as="article">
				<h3>What if I go over my allowance?</h3>
				<p>Taper does not punish you. It tracks what happened and keeps your plan going. The goal is progress, not perfection.</p>
			</Card>
			<Card as="article">
				<h3>Is Taper free?</h3>
				<p>Yes. Taper is free to download and use.</p>
			</Card>
		</div>
	</Section>
</SeoLandingLayout>
