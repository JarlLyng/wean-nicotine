---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import ScreenshotGallery from '../../components/ScreenshotGallery.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Hämta i App Store' : 'Kommer snart i App Store';

const faqItems = [
	{
		question: 'Hur hjälper Taper mig att minska snusandet?',
		answer: 'Taper skapar en plan för gradvis nedtrappning baserat på din nuvarande dagliga konsumtion. Varje vecka sänks din dagliga ranson en aning, så att du drar ner steg för steg istället för att tvärsluta.',
	},
	{
		question: 'Fungerar Taper även för nikotinpåsar?',
		answer: 'Ja. Taper fungerar både för snus och vitt snus (nikotinpåsar). Nedtrappningsmetoden är densamma oavsett vilken produkt du använder.',
	},
	{
		question: 'Är detta medicinsk rådgivning?',
		answer: 'Nej. Taper är ett självhjälpsverktyg för att spåra och minska nikotin gradvis. Det ger ingen medicinsk rådgivning eller klinisk behandling.',
	},
	{
		question: 'Var lagras min data?',
		answer: 'All data stannar på din enhet. Taper kräver inget konto och synkar ingenting till molnet.',
	},
	{
		question: 'Kan jag radera allting?',
		answer: 'Ja. Använd "Start Over" (Börja om) inuti appen för att radera all lokal data, eller ta bara bort appen helt.',
	},
	{
		question: 'Fungerar Taper offline?',
		answer: 'Ja. Eftersom Taper i första hand är lokalt, fungerar alla viktiga funktioner utan internetuppkoppling.',
	},
	{
		question: 'Kan jag spåra nikotinpåsar utan att skapa ett konto?',
		answer: 'Ja. Taper kräver inga konton, ingen inloggning och ingen registrering. Du kan börja direkt.',
	},
	{
		question: 'Är Taper gratis?',
		answer: 'Ja. Taper är gratis att ladda ner och använda.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const screenshots = [
	{
		src: '/screenshots/01-onboarding.png',
		alt: 'Startskärm: välj vanliga triggers som stress, efter maten eller sociala situationer.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/02-today.png',
		alt: 'Idag-skärm: daglig ranson på 6 av 12 dosor med enkel loggning om du använde en påse eller stod emot suget.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/03-progress.png',
		alt: 'Framstegsskärm: veckostatistik över undvikna påsar, dagar under gränsen och (valfritt) sparade pengar.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/04-tools.png',
		alt: 'Stödverktyg: andningsövningar och vägledning för att hantera nikotinsuget.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/05-price-setup.png',
		alt: 'Pris per dosa: håll eventuellt koll på sparade pengar med valfri valuta.',
		width: 590,
		height: 1278,
	},
];
---

<Layout
	title="Minska Snus & Nikotinpåsar | App för Nedtrappning"
	description="Trappa ner på snus och nikotinpåsar gradvis med en lugn, privat app. Följ din dagliga kvot, registrera med ett klick och få stöd när suget slår till."
	canonicalPath="/sv/"
>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<section class="hero">
		<div class="container hero__inner">
			<div class="hero__copy">
				<p class="hero__kicker">Lugn. Privat. Ingen skam.</p>
				<h1>Minska snus och nikotinpåsar – steg för steg.</h1>
				<p class="hero__subline">
					{SITE_NAME} hjälper dig att trappa ner gradvis med en daglig ranson, snabb registrering och stödverktyg när suget slår till.
				</p>

				<div class="hero__cta">
					<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
						{appStoreCtaLabel}
					</Button>
					<Button variant="secondary" href="/sv/privacy">Läs integritetspolicy</Button>
				</div>

				<p class="hero__fineprint">
					Inga konton. Ingen spårning. Data stannar på din enhet.
				</p>
			</div>

			<div class="hero__visual" aria-hidden="true">
				<div class="hero__blob"></div>
				<div class="hero__frame">
					<img
						src="/screenshots/Hero.png"
						alt="Taper app, visar dagen idag-översikten"
						width="780"
						height="1691"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
				</div>
			</div>
		</div>
	</section>

	<Section id="how" title="Så här trappar du ner på snus eller nikotinpåsar gradvis" lede="En enkel och skonsam process du kan hålla fast vid.">
		<div class="grid-3">
			<Card as="article">
				<h3>1) Sätt din baslinje</h3>
				<p>Berätta för Taper hur många påsar du använder per dag. Lägg eventuellt till pris per dosa.</p>
			</Card>
			<Card as="article">
				<h3>2) Följ din dagliga kvot</h3>
				<p>Få ett tydligt dagligt mål och checka in med ett tryck: "Använde en påse" eller "Stod emot suget".</p>
			</Card>
			<Card as="article">
				<h3>3) Spåra framsteg + använd verktyg</h3>
				<p>Se veckans framsteg och använd andningsövningar och reflektioner för att hantera suget.</p>
			</Card>
		</div>
	</Section>

	<Section id="screenshots" title="Skärmbilder" lede="En titt på de viktigaste funktionerna.">
		<ScreenshotGallery items={screenshots} />
	</Section>

	<Section
		id="features"
		title="Följ dina framsteg privat på din enhet"
		lede="Allt du behöver för att minska gradvis – helt utan konton, skam eller brus."
	>
		<div class="grid-2">
			<Card as="article">
				<h3>Idag</h3>
				<p>Daglig kvot, snabb registrering och ett lugnt incheckningsflöde.</p>
			</Card>
			<Card as="article">
				<h3>Framsteg</h3>
				<p>Veckotrender och totaler som hur många påsar du undvikit och (valfritt) sparade pengar.</p>
			</Card>
			<Card as="article">
				<h3>Stödverktyg</h3>
				<p>Andning, reflektion och stöd för att "surfa suget" när nikotinabstinensen slår till.</p>
			</Card>
			<Card as="article">
				<h3>Notiser (valfritt)</h3>
				<p>Dagligen stämmer vi av och påminnelser finns om du aktiverar dem.</p>
			</Card>
			<Card as="article">
				<h3>Börja om</h3>
				<p>Radera lokala data helt och återgå till startskärmen när du vill.</p>
			</Card>
			<Card as="article">
				<h3>Lokalt först</h3>
				<p>Dina data sparas endast på din enhet. Inga inlogg. Ingen molnsynk.</p>
			</Card>
		</div>
	</Section>

	<Section
		id="privacy"
		title="Integritet som standard"
		lede="En privat nikotinspårare som håller kvar dina framsteg på din enhet – ingen delning, ingen molnsynk."
	>
		<div class="grid-2">
			<Card as="article">
				<h3>Vad som stannar på din enhet</h3>
				<ul>
					<li>Användningshistorik (använde en påse / stod emot suget + tidsstämplar)</li>
					<li>Inställningar (baslinje, planparametrar, valfria triggers och ev. pris)</li>
					<li>Dina egna val (tema, notiser)</li>
				</ul>
			</Card>
			<Card as="article">
				<h3>Vad vi inte gör</h3>
				<ul>
					<li>Inga konton eller inloggningar</li>
					<li>Ingen annonsspårning</li>
					<li>Vi säljer ingen personlig data</li>
					<li>Inga medicinska påståenden</li>
				</ul>
			</Card>
			<Card as="article">
				<h3>Radera allt</h3>
				<p>
					"Börja om" (Start over) raderar all lokal data inuti appen och gör så att du kan starta på nytt.
				</p>
			</Card>
			<Card as="article">
				<h3>Kraschrapportering (valfritt)</h3>
				<p>
					Om det är aktiverat i builden kan Sentry ibland användas för felrapporter i syfte att öka appens stabilitet.
				</p>
			</Card>
		</div>
	</Section>

	<Section id="faq" title="Vanliga frågor" lede="Gemensamma frågor om snusreducering och att spåra nikotinpåsar.">
		<div class="grid-2">
			<Card as="article"><h3>{faqItems[0].question}</h3><p>{faqItems[0].answer}</p></Card>
			<Card as="article"><h3>{faqItems[1].question}</h3><p>{faqItems[1].answer}</p></Card>
			<Card as="article"><h3>{faqItems[2].question}</h3><p>{faqItems[2].answer}</p></Card>
			<Card as="article"><h3>{faqItems[3].question}</h3><p>{faqItems[3].answer}</p></Card>
			<Card as="article"><h3>{faqItems[4].question}</h3><p>{faqItems[4].answer}</p></Card>
			<Card as="article"><h3>{faqItems[5].question}</h3><p>{faqItems[5].answer}</p></Card>
			<Card as="article"><h3>{faqItems[6].question}</h3><p>{faqItems[6].answer}</p></Card>
			<Card as="article"><h3>{faqItems[7].question}</h3><p>{faqItems[7].answer}</p></Card>
		</div>
	</Section>
</Layout>

<style>
	.hero {
		padding: clamp(54px, 7vw, 96px) 0;
		border-bottom: 1px solid var(--border-subtle);
	}

	.hero__inner {
		display: grid;
		gap: clamp(24px, 4vw, 48px);
		grid-template-columns: 1.2fr 0.8fr;
		align-items: center;
	}

	.hero__kicker {
		margin: 0 0 var(--space-md);
		color: var(--text-tertiary);
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	h1 {
		margin: 0 0 var(--space-lg);
		font-size: clamp(42px, 6vw, 56px);
		line-height: 1.03;
		letter-spacing: -0.03em;
	}

	.hero__subline {
		margin: 0 0 var(--space-xl);
		color: var(--text-secondary);
		max-width: 62ch;
		font-size: 18px;
		line-height: 28px;
	}

	.hero__cta {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
		align-items: center;
	}

	.hero__fineprint {
		margin: var(--space-lg) 0 0;
		color: var(--text-tertiary);
		font-size: 14px;
	}

	.hero__visual {
		position: relative;
		display: grid;
		place-items: center;
	}

	.hero__blob {
		position: absolute;
		inset: -40px;
		background: radial-gradient(
			circle at 30% 20%,
			color-mix(in oklab, var(--primary), transparent 50%),
			transparent 55%
		);
		filter: blur(10px);
	}

	.hero__frame {
		position: relative;
		border-radius: 28px;
		border: 1px solid var(--border-subtle);
		background: var(--surface-raised);
		overflow: hidden;
		box-shadow: 0 24px 80px color-mix(in oklab, var(--text-primary), transparent 88%);
		max-width: 320px;
	}

	.hero__frame img {
		display: block;
		width: 100%;
		height: auto;
	}

	.grid-2,
	.grid-3 {
		display: grid;
		gap: var(--space-lg);
	}

	.grid-2 {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.grid-3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	h3 {
		margin: 0 0 var(--space-sm);
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	p {
		margin: 0;
		color: var(--text-secondary);
	}

	ul {
		margin: var(--space-sm) 0 0;
		padding-left: 18px;
		color: var(--text-secondary);
	}

	li {
		margin: 6px 0;
	}

	@media (max-width: 960px) {
		.hero__inner {
			grid-template-columns: 1fr;
		}

		.hero__frame {
			max-width: 360px;
		}

		.grid-3 {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 700px) {
		.grid-2 {
			grid-template-columns: 1fr;
		}
	}
</style>
