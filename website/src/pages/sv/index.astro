---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import ScreenshotGallery from '../../components/ScreenshotGallery.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Hämta i App Store' : 'Kommer snart i App Store';

const faqItems = [
	{
		question: 'Hur hjälper Taper mig att minska snusandet?',
		answer: 'Taper skapar en plan för gradvis nedtrappning baserat på din nuvarande dagliga konsumtion. Varje vecka sänks din dagliga ranson en aning, så att du drar ner steg för steg istället för att tvärsluta.',
	},
	{
		question: 'Fungerar Taper även för nikotinpåsar?',
		answer: 'Ja. Taper fungerar både för snus och vitt snus (nikotinpåsar). Nedtrappningsmetoden är densamma oavsett vilken produkt du använder.',
	},
	{
		question: 'Är detta medicinsk rådgivning?',
		answer: 'Nej. Taper är ett självhjälpsverktyg för att spåra och minska nikotin gradvis. Det ger ingen medicinsk rådgivning eller klinisk behandling.',
	},
	{
		question: 'Var lagras min data?',
		answer: 'All data stannar på din enhet. Taper kräver inget konto och synkar ingenting till molnet.',
	},
	{
		question: 'Kan jag radera allting?',
		answer: 'Ja. Använd "Start Over" (Börja om) inuti appen för att radera all lokal data, eller ta bara bort appen helt.',
	},
	{
		question: 'Fungerar Taper offline?',
		answer: 'Ja. Eftersom Taper i första hand är lokalt, fungerar alla viktiga funktioner utan internetuppkoppling.',
	},
	{
		question: 'Kan jag spåra nikotinpåsar utan att skapa ett konto?',
		answer: 'Ja. Taper kräver inga konton, ingen inloggning och ingen registrering. Du kan börja direkt.',
	},
	{
		question: 'Vad kostar Taper?',
		answer: 'Taper är ett engångsköp — inga prenumerationer, inga annonser och ingen dataförsäljning. Du betalar en gång och får alla funktioner, byggt av en oberoende soloutvecklare.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const screenshots = [
	{
		src: '/screenshots/v1.1/02.png',
		alt: 'Startskärm: välj vanliga triggers som stress, efter maten eller sociala situationer.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/03.png',
		alt: 'Idag-skärm: daglig ranson på 6 av 12 dosor med enkel loggning om du använde en påse eller stod emot suget.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/04.png',
		alt: 'Framstegsskärm: veckostatistik över undvikna påsar, dagar under gränsen och (valfritt) sparade pengar.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/05.png',
		alt: 'Stödverktyg: andningsövningar och vägledning för att hantera nikotinsuget.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/06.png',
		alt: 'Pris per dosa: håll eventuellt koll på sparade pengar med valfri valuta.',
		width: 590,
		height: 1278,
	},
];
---

<Layout
	title="Minska Snus & Nikotinpåsar | App för Nedtrappning"
	description="Trappa ner på snus och nikotinpåsar gradvis med en lugn, privat app. Följ din dagliga kvot, registrera med ett klick och få stöd när suget slår till."
	canonicalPath="/sv/"
>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<section class="hero">
		<div class="nordic-bg" style="background-image: url('/images/unsplash/nordic-3.jpg');"></div>
		<div class="container hero__inner">
			<div class="hero__copy reveal">
				<p class="hero__kicker">Lugn. Privat. Ingen skam.</p>
				<h1>Minska nikotinet i din egen takt.</h1>
				<p class="hero__subline">
					{SITE_NAME} är en lugn och privat app som hjälper dig att trappa ner på snus och nikotinpåsar — helt utan dömande eller abonnemang.
				</p>

				<div class="hero__cta">
					<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
						{appStoreCtaLabel}
					</Button>
					<Button variant="secondary" href="/sv/privacy">Se integritetspolicy</Button>
				</div>

				<p class="hero__fineprint">
					Inga konton. Ingen spårning. Inga prenumerationer. All data stannar på din enhet.
				</p>
			</div>

			<div class="hero__visual reveal" aria-hidden="true">
				<div class="hero__frame anim-float">
					<img
						src="/screenshots/v1.1/01.png"
						alt="Taper app, visar dagen idag-översikten"
						width="780"
						height="1691"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
				</div>
			</div>
		</div>
	</section>

	<Section id="how" title="Så fungerar det" lede="En enkel och skonsam process du kan hålla fast vid.">
		<div class="grid-3">
			<Card as="article">
				<h3>1) Sätt din baslinje</h3>
				<p>Berätta för Taper hur många påsar du använder per dag och ditt nuvarande pris.</p>
			</Card>
			<Card as="article">
				<h3>2) Följ din kvot</h3>
				<p>Få ett tydligt mål varje dag och logga med ett tryck: "Använde en" eller "Stod emot".</p>
			</Card>
			<Card as="article">
				<h3>3) Använd verktygen</h3>
				<p>Använd andningsövningar, reflektion och se pengarna du sparar varje vecka.</p>
			</Card>
		</div>
	</Section>

	<Section
		id="features"
		title="Verktyg som gör skillnad"
		lede="Allt du behöver för att minska gradvis – helt utan konton, skam eller brus."
	>
		<div class="grid-3">
			<Card as="article">
				<h3>Interaktiv andning</h3>
				<p>Lugna nervsystemet med 4-7-8, Box Breathing eller Quick Calm-vibrationer.</p>
			</Card>
			<Card as="article">
				<h3>Guidad Urge Surfing</h3>
				<p>En 5-minuters timer som hjälper dig att observera och 'rida ut' suget.</p>
			</Card>
			<Card as="article">
				<h3>Reflektions-anteckningar</h3>
				<p>Spara korta anteckningar om dina triggers och framsteg för att förstå dina mönster.</p>
			</Card>
			<Card as="article">
				<h3>Ekonomisk översikt</h3>
				<p>Se exakt hur mycket pengar du har sparat sedan du började — direkt på din iPhone.</p>
			</Card>
			<Card as="article">
				<h3>Integritet först</h3>
				<p>Inga konton. Inget moln. Dina data lagras lokalt och krypterat på din egen enhet.</p>
			</Card>
			<Card as="article">
				<h3>Inga abonnemang</h3>
				<p>Betala en gång, äg appen för alltid. Inga dolda avgifter eller återkommande betalningar.</p>
			</Card>
		</div>
	</Section>

	<Section id="faq" title="Vanliga frågor" lede="Gemensamma frågor om snusreducering och att spåra nikotinpåsar.">
		<div class="grid-2">
			<Card as="article"><h3>{faqItems[0].question}</h3><p>{faqItems[0].answer}</p></Card>
			<Card as="article"><h3>{faqItems[1].question}</h3><p>{faqItems[1].answer}</p></Card>
			<Card as="article"><h3>{faqItems[2].question}</h3><p>{faqItems[2].answer}</p></Card>
			<Card as="article"><h3>{faqItems[3].question}</h3><p>{faqItems[3].answer}</p></Card>
			<Card as="article"><h3>{faqItems[4].question}</h3><p>{faqItems[4].answer}</p></Card>
			<Card as="article"><h3>{faqItems[5].question}</h3><p>{faqItems[5].answer}</p></Card>
			<Card as="article"><h3>{faqItems[6].question}</h3><p>{faqItems[6].answer}</p></Card>
			<Card as="article"><h3>{faqItems[7].question}</h3><p>{faqItems[7].answer}</p></Card>
		</div>
	</Section>
</Layout>

<style>
	.hero {
		position: relative;
		padding: clamp(80px, 15vw, 160px) 0;
		min-height: clamp(600px, 80vh, 1000px);
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero__inner {
		display: grid;
		gap: clamp(40px, 6vw, 80px);
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
	}

	.hero__kicker {
		margin: 0 0 var(--space-md);
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 13px;
	}

	.hero__subline {
		margin: var(--space-xl) 0 var(--space-xxxl);
		color: var(--text-secondary);
		font-size: clamp(18px, 2vw, 21px);
		line-height: var(--line-height-relaxed);
		max-width: 50ch;
	}

	.hero__cta {
		display: flex;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.hero__fineprint {
		margin: var(--space-xxxl) 0 0;
		color: var(--text-tertiary);
		font-size: 13px;
		font-weight: 500;
	}

	.hero__visual {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.hero__frame {
		position: relative;
		border-radius: var(--radius-xl);
		border: 1px solid var(--border-glass);
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(20px);
		padding: 1px;
		box-shadow: 0 40px 100px rgba(0, 0, 0, 0.25);
		max-width: 340px;
		overflow: hidden;
	}

	.hero__frame img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: inherit;
	}

	@media (max-width: 1100px) {
		.hero__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.hero__copy {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.hero__subline {
			margin-left: auto;
			margin-right: auto;
		}

		.hero__cta {
			justify-content: center;
		}
	}
</style>
