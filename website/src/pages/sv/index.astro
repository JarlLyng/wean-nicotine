---
import NordicHome, { type NordicHomeContent } from '../../components/NordicHome.astro';
import { SITE_NAME } from '../../lib/site';

const content: NordicHomeContent = {
	meta: {
		title: 'Minska Snus & Nikotinpåsar | App för Nedtrappning',
		description:
			'Trappa ner på snus och nikotinpåsar gradvis med en lugn, privat app. Följ din dagliga kvot, registrera med ett klick och få stöd när suget slår till.',
	},
	hero: {
		kicker: 'Lugn. Privat. Ingen skam.',
		heading: 'Minska nikotinet i din egen takt.',
		subline: `${SITE_NAME} är en lugn och privat app som hjälper dig att trappa ner på snus och nikotinpåsar — helt utan dömande eller abonnemang.`,
		ctaKnown: 'Hämta i App Store',
		ctaUnknown: 'Kommer snart i App Store',
		privacyLabel: 'Se integritetspolicy',
		fineprint:
			'Inga konton · Ingen användningsspårning · Inga prenumerationer · Din data stannar på enheten',
		imageAlt: 'Wean Nicotine app, visar dagen idag-översikten',
	},
	how: {
		title: 'Så fungerar det',
		lede: 'En enkel och skonsam process du kan hålla fast vid.',
		steps: [
			{
				title: '1) Sätt din baslinje',
				text: 'Berätta för Wean hur många påsar du använder per dag och ditt nuvarande pris.',
			},
			{
				title: '2) Följ din kvot',
				text: 'Få ett tydligt mål varje dag och logga med ett tryck: "Använde en" eller "Stod emot".',
			},
			{
				title: '3) Använd verktygen',
				text: 'Använd andningsövningar, reflektion och se pengarna du sparar varje vecka.',
			},
		],
	},
	features: {
		title: 'Verktyg som gör skillnad',
		lede: 'Allt du behöver för att minska gradvis – helt utan konton, skam eller brus.',
		cards: [
			{
				title: 'Interaktiv andning',
				text: 'Lugna nervsystemet med 4-7-8, Box Breathing eller Quick Calm-vibrationer.',
			},
			{
				title: 'Guidad Urge Surfing',
				text: "En 5-minuters timer som hjälper dig att observera och 'rida ut' suget.",
			},
			{
				title: 'Reflektions-anteckningar',
				text: 'Spara korta anteckningar om dina triggers och framsteg för att förstå dina mönster.',
			},
			{
				title: 'Ekonomisk översikt',
				text: 'Se exakt hur mycket pengar du har sparat sedan du började — direkt på din iPhone.',
			},
			{
				title: 'Integritet först',
				text: 'Inga konton, ingen molnsynk, ingen användningsspårning. Dina loggar och plan stannar på din enhet.',
			},
			{
				title: 'Inga abonnemang',
				text: 'Betala en gång, äg appen för alltid. Inga dolda avgifter eller återkommande betalningar.',
			},
		],
	},
	faq: {
		title: 'Vanliga frågor',
		lede: 'Gemensamma frågor om snusreducering och att spåra nikotinpåsar.',
		items: [
			{
				question: 'Hur hjälper Wean Nicotine mig att minska snusandet?',
				answer:
					'Wean Nicotine skapar en plan för gradvis nedtrappning baserat på din nuvarande dagliga konsumtion. Varje vecka sänks din dagliga ranson en aning, så att du drar ner steg för steg istället för att tvärsluta.',
			},
			{
				question: 'Fungerar Wean Nicotine även för nikotinpåsar?',
				answer:
					'Ja. Wean Nicotine fungerar både för snus och vitt snus (nikotinpåsar). Nedtrappningsmetoden är densamma oavsett vilken produkt du använder.',
			},
			{
				question: 'Är detta medicinsk rådgivning?',
				answer:
					'Nej. Wean Nicotine är ett självhjälpsverktyg för att spåra och minska nikotin gradvis. Det ger ingen medicinsk rådgivning eller klinisk behandling.',
			},
			{
				question: 'Var lagras min data?',
				answer:
					'All data stannar på din enhet. Wean Nicotine kräver inget konto och synkar ingenting till molnet.',
