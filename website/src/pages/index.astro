---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Download on the App Store' : 'Coming soon on the App Store';

const faqItems = [
	{
		question: 'How does Taper help me reduce snus?',
		answer: 'Taper creates a gradual reduction plan based on your current daily use. Each week your daily allowance decreases slightly, so you cut down step by step instead of quitting cold turkey.',
	},
	{
		question: 'Does Taper work for nicotine pouches too?',
		answer: 'Yes. Taper works for both snus and nicotine pouches. The tapering approach is the same regardless of which product you use.',
	},
	{
		question: 'Is this medical advice?',
		answer: 'No. Taper is a self-help tracking tool for gradual nicotine reduction. It does not provide medical advice or clinical treatment.',
	},
	{
		question: 'Where is my data stored?',
		answer: 'All data stays on your device. Taper does not require an account and does not sync to the cloud.',
	},
	{
		question: 'Can I delete everything?',
		answer: 'Yes. Use "Start Over" inside the app to delete all local data and return to onboarding, or simply delete the app.',
	},
	{
		question: 'Does Taper work offline?',
		answer: 'Yes. Because Taper is local-first, all core features work without an internet connection.',
	},
	{
		question: 'Can I track nicotine pouches without creating an account?',
		answer: 'Yes. Taper requires no accounts, no login, and no sign-up. You can start tracking immediately.',
	},
	{
		question: 'What does Taper cost?',
		answer: 'Taper is a one-time purchase — no subscriptions, no ads, and no data selling. You pay once and get every feature, built by an independent solo developer.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const screenshots = [
	{
		src: '/screenshots/v1.1/02.png',
		alt: 'Onboarding screen: select common triggers like stress, after meals, and social situations.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/03.png',
		alt: 'Today screen: daily allowance of 6 out of 12 pouches with one-tap logging for used pouches and resisted cravings.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/04.png',
		alt: 'Progress screen: weekly stats showing pouches avoided, days under limit, cravings resisted, and money saved.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/05.png',
		alt: 'Support tools: breathing exercise, reflection prompts, and urge surfing for managing cravings.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/06.png',
		alt: 'Price per can setup: optionally track money saved with currency selection.',
		width: 590,
		height: 1278,
	},
];
---

<Layout
	description="Reduce snus and nicotine pouches gradually with a calm, private app. Track your daily allowance, log use in one tap, and get support when cravings hit."
	canonicalPath="/"
>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<section class="hero">
		<div class="nordic-bg" style="background-image: url('/images/unsplash/nordic-4.jpg');"></div>
		<div class="container hero__inner">
			<div class="hero__copy reveal">
				<p class="hero__kicker">Calm. Private. No shame.</p>
				<h1>A gentler way to quit nicotine.</h1>
				<p class="hero__subline">
					{SITE_NAME} is a calm and private app designed to help you reduce snus and nicotine pouches gradually, at your own pace.
				</p>

				<div class="hero__cta">
					<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
						{appStoreCtaLabel}
					</Button>
					<Button variant="secondary" href="/privacy">View privacy policy</Button>
				</div>

				<p class="hero__fineprint">
					No accounts. No tracking. No subscriptions. Your data stays on your device.
				</p>
			</div>

			<div class="hero__visual reveal" aria-hidden="true">
				<div class="hero__frame anim-float">
					<img
						src="/screenshots/v1.1/01.png"
						alt="Taper app showing daily allowance tracking"
						width="780"
						height="1691"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
				</div>
			</div>
		</div>
	</section>

	<Section id="how" title="How it works" lede="A simple, gentle process you can stick with.">
		<div class="grid-3">
			<Card as="article">
				<h3>1) Set your baseline</h3>
				<p>Tell Taper how many pouches you use per day and your current price per can.</p>
			</Card>
			<Card as="article">
				<h3>2) Follow your allowance</h3>
				<p>Get a clear daily number and log in one tap: "Used one" or "Resisted".</p>
			</Card>
			<Card as="article">
				<h3>3) Use the tools</h3>
				<p>Leverage breathing exercises, reflection, and see your weekly savings grow.</p>
			</Card>
		</div>
	</Section>

	<Section
		id="features"
		title="Tools built for your journey"
		lede="Everything you need to reduce gradually — without accounts, shame, or noise."
	>
		<div class="grid-3">
			<Card as="article">
				<h3>Interactive Breathing</h3>
				<p>Calm your nervous system with 4-7-8, Box Breathing, or Quick Calm vibrations.</p>
			</Card>
			<Card as="article">
				<h3>Guided Urge Surfing</h3>
				<p>A 5-minute guided timer that helps you observe and 'ride' the nicotine craving.</p>
			</Card>
			<Card as="article">
				<h3>Reflection Journal</h3>
				<p>Save short notes about your triggers and progress to understand your patterns.</p>
			</Card>
			<Card as="article">
				<h3>Financial Overview</h3>
				<p>See exactly how much money you have saved since you started — right on your device.</p>
			</Card>
			<Card as="article">
				<h3>Privacy by Default</h3>
				<p>No accounts. No cloud. Your data is stored locally and encrypted on your own device.</p>
			</Card>
			<Card as="article">
				<h3>No Subscriptions</h3>
				<p>Pay once, own the app forever. No hidden fees or recurring payments.</p>
			</Card>
		</div>
	</Section>

	<Section id="faq" title="Frequently asked questions" lede="Common questions about snus reduction and nicotine pouch tracking.">
		<div class="grid-2">
			<Card as="article"><h3>{faqItems[0].question}</h3><p>{faqItems[0].answer}</p></Card>
			<Card as="article"><h3>{faqItems[1].question}</h3><p>{faqItems[1].answer}</p></Card>
			<Card as="article"><h3>{faqItems[2].question}</h3><p>{faqItems[2].answer}</p></Card>
			<Card as="article"><h3>{faqItems[3].question}</h3><p>{faqItems[3].answer}</p></Card>
			<Card as="article"><h3>{faqItems[4].question}</h3><p>{faqItems[4].answer}</p></Card>
			<Card as="article"><h3>{faqItems[5].question}</h3><p>{faqItems[5].answer}</p></Card>
			<Card as="article"><h3>{faqItems[6].question}</h3><p>{faqItems[6].answer}</p></Card>
			<Card as="article"><h3>{faqItems[7].question}</h3><p>{faqItems[7].answer}</p></Card>
		</div>
	</Section>
</Layout>

<style>
	.hero {
		position: relative;
		padding: clamp(80px, 15vw, 160px) 0;
		min-height: clamp(600px, 80vh, 1000px);
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero__inner {
		display: grid;
		gap: clamp(40px, 6vw, 80px);
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
	}

	.hero__kicker {
		margin: 0 0 var(--space-md);
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 13px;
	}

	.hero__subline {
		margin: var(--space-xl) 0 var(--space-xxxl);
		color: var(--text-secondary);
		font-size: clamp(18px, 2vw, 21px);
		line-height: var(--line-height-relaxed);
		max-width: 50ch;
	}

	.hero__cta {
		display: flex;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.hero__fineprint {
		margin: var(--space-xxxl) 0 0;
		color: var(--text-tertiary);
		font-size: 13px;
		font-weight: 500;
	}

	.hero__visual {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.hero__frame {
		position: relative;
		border-radius: var(--radius-xl);
		border: 1px solid var(--border-glass);
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(20px);
		padding: 1px;
		box-shadow: 0 40px 100px rgba(0, 0, 0, 0.25);
		max-width: 340px;
		overflow: hidden;
	}

	.hero__frame img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: inherit;
	}

	@media (max-width: 1100px) {
		.hero__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.hero__copy {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.hero__subline {
			margin-left: auto;
			margin-right: auto;
		}

		.hero__cta {
			justify-content: center;
		}
	}
</style>
