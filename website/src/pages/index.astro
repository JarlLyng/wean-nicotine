---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Download on the App Store' : 'Coming soon on the App Store';

const faqItems = [
	{
		question: 'How does Taper help me reduce snus?',
		answer: 'Taper creates a gradual reduction plan based on your current daily use. Each week your daily allowance decreases slightly, so you cut down step by step instead of quitting cold turkey.',
	},
	{
		question: 'Does Taper work for nicotine pouches too?',
		answer: 'Yes. Taper works for both snus and nicotine pouches. The tapering approach is the same regardless of which product you use.',
	},
	{
		question: 'Is this medical advice?',
		answer: 'No. Taper is a self-help tracking tool for gradual nicotine reduction. It does not provide medical advice or clinical treatment.',
	},
	{
		question: 'Where is my data stored?',
		answer: 'All data stays on your device. Taper does not require an account and does not sync to the cloud.',
	},
	{
		question: 'Can I delete everything?',
		answer: 'Yes. Use "Start Over" inside the app to delete all local data and return to onboarding, or simply delete the app.',
	},
	{
		question: 'Does Taper work offline?',
		answer: 'Yes. Because Taper is local-first, all core features work without an internet connection.',
	},
	{
		question: 'Can I track nicotine pouches without creating an account?',
		answer: 'Yes. Taper requires no accounts, no login, and no sign-up. You can start tracking immediately.',
	},
	{
		question: 'What does Taper cost?',
		answer: 'Taper is a one-time purchase — no subscriptions, no ads, and no data selling. You pay once and get every feature, built by an independent solo developer.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const screenshots = [
	{
		src: '/screenshots/v1.1/02.png',
		alt: 'Onboarding screen: select common triggers like stress, after meals, and social situations.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/03.png',
		alt: 'Today screen: daily allowance of 6 out of 12 pouches with one-tap logging for used pouches and resisted cravings.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/04.png',
		alt: 'Progress screen: weekly stats showing pouches avoided, days under limit, cravings resisted, and money saved.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/05.png',
		alt: 'Support tools: breathing exercise, reflection prompts, and urge surfing for managing cravings.',
		width: 590,
		height: 1278,
	},
	{
		src: '/screenshots/v1.1/06.png',
		alt: 'Price per can setup: optionally track money saved with currency selection.',
		width: 590,
		height: 1278,
	},
];
---

<Layout
	description="Reduce snus and nicotine pouches gradually with a calm, private app. Track your daily allowance, log use in one tap, and get support when cravings hit."
	canonicalPath="/"
>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<section class="hero">
		<div class="container hero__inner">
			<div class="hero__copy">
				<p class="hero__kicker">Calm. Private. No shame.</p>
				<h1>Reduce snus and nicotine pouches — step by step.</h1>
				<p class="hero__subline">
					{SITE_NAME} helps you taper gradually with a daily allowance, one‑tap tracking, and supportive
					tools when cravings hit.
				</p>

				<div class="hero__cta">
					<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true}>
						{appStoreCtaLabel}
					</Button>
					<Button variant="secondary" href="/privacy">Read privacy policy</Button>
				</div>

				<p class="hero__fineprint">
					No accounts. No tracking. No subscriptions. Data stays on your device.
				</p>
			</div>

			<div class="hero__visual" aria-hidden="true">
				<div class="hero__blob"></div>
				<div class="hero__frame anim-float">
					<img
						src="/screenshots/v1.1/01.png"
						alt="Taper app Today screen showing daily allowance tracking"
						width="780"
						height="1691"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
				</div>
			</div>
		</div>
	</section>

	<div class="bg-section">
		
		<div class="bg-section__overlay"></div>
		<div class="bg-section__content">
			<Section id="how" title="How to reduce snus or nicotine pouches gradually" lede="A simple, gentle process you can stick with.">
				<div class="features-split">
					<div class="features-split__content">
						<Card as="article">
							<h3>1) Set your baseline</h3>
							<p>Tell Taper how many pouches you use per day. Optionally add price per can.</p>
						</Card>
						<Card as="article">
							<h3>2) Follow your daily allowance</h3>
							<p>Get a clear daily number and check in with one tap: "Used a pouch" or "Resisted craving".</p>
						</Card>
						<Card as="article">
							<h3>3) Track progress + use tools</h3>
							<p>See weekly and total progress, and use breathing, urge surfing, and reflection prompts.</p>
						</Card>
					</div>
					<div class="features-split__image app-floating-image">
						<div class="glass-panel screenshot-wrapper anim-float-delayed">
							<img src="/screenshots/v1.1/03.png" alt="Taper Today screen showing daily allowance and tracking" width="590" height="1278" loading="lazy" />
						</div>
					</div>
				</div>
			</Section>
		</div>
	</div>

	<Section id="screenshots" title="Screenshots" lede="A peek at the core flows.">
		<ScreenshotGallery items={screenshots} />
	</Section>

	<Section
		id="features"
		title="Track progress privately on your device"
		lede="Everything you need to reduce gradually — without accounts, shame, or noise."
	>
		<div class="grid-2">
			<Card as="article">
				<h3>Today</h3>
				<p>Daily allowance, quick logging, and a calm check‑in flow.</p>
			</Card>
			<Card as="article">
				<h3>Progress</h3>
				<p>Weekly trends and totals like pouches avoided and (optional) money saved.</p>
			</Card>
			<Card as="article">
				<h3>Support tools</h3>
				<p>Breathing, urge surfing, and reflection prompts when cravings hit.</p>
			</Card>
			<Card as="article">
				<h3>Notifications (optional)</h3>
				<p>Daily check‑ins and trigger reminders if you enable them.</p>
			</Card>
			<Card as="article">
				<h3>Start Over</h3>
				<p>Delete local data and return to onboarding anytime.</p>
			</Card>
			<Card as="article">
				<h3>Local‑first</h3>
				<p>Your data is stored on your device. No accounts. No cloud sync.</p>
			</Card>
		</div>
	</Section>

	<div class="bg-section">
		
		<div class="bg-section__overlay"></div>
		<div class="bg-section__content">
			<Section
				id="privacy"
				title="Privacy-first by design"
				lede="A private nicotine tracker that keeps your progress on your device — no accounts, no cloud sync."
			>
				<div class="features-split features-split--reverse">
					<div class="features-split__image app-floating-image">
						<div class="glass-panel screenshot-wrapper anim-float">
							<img src="/screenshots/v1.1/05.png" alt="Taper support tools including breathing exercises and urge surfing" width="590" height="1278" loading="lazy" />
						</div>
					</div>
					<div class="features-split__content">
						<Card as="article">
							<h3>What stays on your device</h3>
							<p>Usage logs, settings, and preferences never leave your phone.</p>
						</Card>
						<Card as="article">
							<h3>What we don't do</h3>
							<p>No accounts or login. No ad tracking. No selling data.</p>
						</Card>
						<Card as="article">
							<h3>Complete control</h3>
							<p>"Start Over" instantly wipes local data and returns you to onboarding.</p>
						</Card>
					</div>
				</div>
			</Section>
		</div>
	</div>

	<Section id="why" title="Why Taper?" lede="Built different from the big health apps.">
		<div class="grid-3">
			<Card as="article">
				<h3>Privacy-first</h3>
				<p>Your data never leaves your phone. No accounts, no cloud sync, no ad tracking. What you log stays yours — period.</p>
			</Card>
			<Card as="article">
				<h3>One-time purchase</h3>
				<p>Pay once, get everything. No subscriptions, no paywalls, no "premium" tier. Every feature is included from day one.</p>
			</Card>
			<Card as="article">
				<h3>Made by a solo developer</h3>
				<p>Taper is built by one person who cares about the product — not a corporation optimizing for engagement metrics.</p>
			</Card>
		</div>
	</Section>

	<Section id="faq" title="Frequently asked questions" lede="Common questions about snus reduction and nicotine pouch tracking.">
		<div class="grid-2">
			<Card as="article"><h3>{faqItems[0].question}</h3><p>{faqItems[0].answer}</p></Card>
			<Card as="article"><h3>{faqItems[1].question}</h3><p>{faqItems[1].answer}</p></Card>
			<Card as="article"><h3>{faqItems[2].question}</h3><p>{faqItems[2].answer}</p></Card>
			<Card as="article"><h3>{faqItems[3].question}</h3><p>{faqItems[3].answer}</p></Card>
			<Card as="article"><h3>{faqItems[4].question}</h3><p>{faqItems[4].answer}</p></Card>
			<Card as="article"><h3>{faqItems[5].question}</h3><p>{faqItems[5].answer}</p></Card>
			<Card as="article"><h3>{faqItems[6].question}</h3><p>{faqItems[6].answer}</p></Card>
			<Card as="article"><h3>{faqItems[7].question}</h3><p>{faqItems[7].answer}</p></Card>
		</div>
	</Section>
</Layout>

<style>
	.hero {
		padding: clamp(54px, 7vw, 96px) 0;
		border-bottom: 1px solid var(--border-subtle);
	}

	.hero__inner {
		display: grid;
		gap: clamp(24px, 4vw, 48px);
		grid-template-columns: 1.2fr 0.8fr;
		align-items: center;
	}

	.hero__kicker {
		margin: 0 0 var(--space-md);
		color: var(--text-tertiary);
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	h1 {
		margin: 0 0 var(--space-lg);
		font-size: clamp(42px, 6vw, 56px);
		line-height: 1.03;
		letter-spacing: -0.03em;
	}

	.hero__subline {
		margin: 0 0 var(--space-xl);
		color: var(--text-secondary);
		max-width: 62ch;
		font-size: 18px;
		line-height: 28px;
	}

	.hero__cta {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
		align-items: center;
	}

	.hero__fineprint {
		margin: var(--space-lg) 0 0;
		color: var(--text-tertiary);
		font-size: 14px;
	}

	.hero__visual {
		position: relative;
		display: grid;
		place-items: center;
	}

	@keyframes pulseBlob {
		0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.8; }
		33% { transform: scale(1.1) translate(2% , 3%); opacity: 1; }
		66% { transform: scale(0.9) translate(-2%, -2%); opacity: 0.9; }
	}

	.hero__blob {
		position: absolute;
		inset: -100px;
		background: 
			radial-gradient(circle at 30% 20%, color-mix(in oklab, var(--primary), transparent 30%), transparent 60%),
			radial-gradient(circle at 70% 80%, color-mix(in oklab, var(--success), transparent 40%), transparent 60%),
			radial-gradient(circle at 50% 50%, color-mix(in oklab, var(--primary), transparent 50%), transparent 70%);
		filter: blur(48px);
		animation: pulseBlob 12s ease-in-out infinite alternate;
	}

	.hero__frame {
		position: relative;
		border-radius: 28px;
		border: 1px solid color-mix(in oklab, var(--border-subtle), transparent 40%);
		background: color-mix(in oklab, var(--surface-raised), transparent 50%);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
		box-shadow: 0 32px 120px color-mix(in oklab, var(--text-primary), transparent 85%);
		max-width: 320px;
		transform: perspective(1000px) rotateY(-5deg) rotateX(2deg);
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
	}
	
	.hero__frame:hover {
		transform: perspective(1000px) rotateY(0deg) rotateX(0deg);
		box-shadow: 0 40px 140px color-mix(in oklab, var(--text-primary), transparent 80%);
	}

	.hero__frame img {
		display: block;
		width: 100%;
		height: auto;
	}

	.grid-2,
	.grid-3 {
		display: grid;
		gap: var(--space-lg);
	}

	.grid-2 {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.grid-3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.features-split {
		display: grid;
		gap: clamp(var(--space-xl), 5vw, var(--space-xxxl));
		grid-template-columns: 1fr 1fr;
		align-items: center;
	}

	.features-split__content {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.app-floating-image {
		display: flex;
		justify-content: center;
		align-items: center;
		perspective: 1200px;
	}

	.screenshot-wrapper {
		max-width: 280px;
		border-radius: 40px;
		padding: 12px;
		transform: rotateY(-10deg) rotateX(5deg) scale(0.95);
		transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 40px 100px color-mix(in oklab, black, transparent 70%);
	}

	.screenshot-wrapper:hover {
		transform: rotateY(0deg) rotateX(0deg) scale(1.05);
	}

	.features-split--reverse .screenshot-wrapper {
		transform: rotateY(10deg) rotateX(5deg) scale(0.95);
	}

	.features-split--reverse .screenshot-wrapper:hover {
		transform: rotateY(0deg) rotateX(0deg) scale(1.05);
	}

	.screenshot-wrapper img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 32px;
	}

	h3 {
		margin: 0 0 var(--space-sm);
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	p {
		margin: 0;
		color: var(--text-secondary);
	}

	ul {
		margin: var(--space-sm) 0 0;
		padding-left: 18px;
		color: var(--text-secondary);
	}

	li {
		margin: 6px 0;
	}

	@media (max-width: 960px) {
		.hero__inner {
			grid-template-columns: 1fr;
		}

		.hero__frame {
			max-width: 360px;
		}

		.grid-3 {
			grid-template-columns: 1fr;
		}
		
		.features-split {
			grid-template-columns: 1fr;
		}

		.features-split--reverse .app-floating-image {
			order: -1;
		}

		.screenshot-wrapper {
			transform: none !important;
			max-width: 240px;
		}
	}

	@media (max-width: 700px) {
		.grid-2 {
			grid-template-columns: 1fr;
		}
	}
</style>
