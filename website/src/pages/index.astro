---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import { APP_STORE_URL, isAppStoreUrlKnown, SITE_NAME } from '../lib/site';

const appStoreKnown = isAppStoreUrlKnown(APP_STORE_URL);
const appStoreCtaLabel = appStoreKnown ? 'Download on the App Store' : 'Coming soon on the App Store';

const faqItems = [
	{
		question: 'How does Wean Nicotine help me reduce snus?',
		answer: 'Wean Nicotine creates a gradual reduction plan based on your current daily use. Each week your daily allowance decreases slightly, so you cut down step by step instead of quitting cold turkey.',
	},
	{
		question: 'Does Wean Nicotine work for nicotine pouches too?',
		answer: 'Yes. Wean Nicotine works for both snus and nicotine pouches. The tapering approach is the same regardless of which product you use.',
	},
	{
		question: 'Is this medical advice?',
		answer: 'No. Wean Nicotine is a self-help tracking tool for gradual nicotine reduction. It does not provide medical advice or clinical treatment.',
	},
	{
		question: 'Where is my data stored?',
		answer: 'All data stays on your device. Wean Nicotine does not require an account and does not sync to the cloud.',
	},
	{
		question: 'Can I delete everything?',
		answer: 'Yes. Use "Start Over" inside the app to delete all local data and return to onboarding, or simply delete the app.',
	},
	{
		question: 'Does Wean Nicotine work offline?',
		answer: 'Yes. Because Wean Nicotine is local-first, all core features work without an internet connection.',
	},
	{
		question: 'Can I track nicotine pouches without creating an account?',
		answer: 'Yes. Wean Nicotine requires no accounts, no login, and no sign-up. You can start tracking immediately.',
	},
	{
		question: 'What does Wean Nicotine cost?',
		answer: 'Wean Nicotine is a one-time purchase — no subscriptions, no ads, and no data selling. You pay once and get every feature, built by an independent solo developer.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const screenshots = [
	{
		src: '/screenshots/v1.2/04-triggers.png',
		alt: 'Onboarding: select common triggers like stress, after meals, with coffee, and social situations.',
		width: 393,
		height: 852,
	},
	{
		src: '/screenshots/v1.2/05-today.png',
		alt: 'Today screen: daily allowance of 3 out of 16 pouches with one-tap logging for used pouches and resisted cravings.',
		width: 393,
		height: 852,
	},
	{
		src: '/screenshots/v1.2/06-progress.png',
		alt: 'Progress screen: weekly stats showing pouches avoided, days on track, cravings resisted, and money saved.',
		width: 393,
		height: 852,
	},
	{
		src: '/screenshots/v1.2/07-tools.png',
		alt: 'Support tools: breathing exercise, reflection prompts, urge surfing, and cost savings.',
		width: 393,
		height: 852,
	},
	{
		src: '/screenshots/v1.2/08-savings.png',
		alt: 'Cost savings: track money saved per day, projected monthly, and weekly breakdown.',
		width: 393,
		height: 852,
	},
];
---

<Layout
	description="Reduce snus and nicotine pouches gradually with a calm, private app. Track your daily allowance, log use in one tap, and get support when cravings hit."
	canonicalPath="/"
>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<!-- ══ HERO ══ -->
	<section class="hero">
		<!-- Animated aurora background -->
		<div class="hero__aurora" aria-hidden="true">
			<div class="hero__aurora-orb hero__aurora-orb--1"></div>
			<div class="hero__aurora-orb hero__aurora-orb--2"></div>
			<div class="hero__aurora-orb hero__aurora-orb--3"></div>
		</div>
		<div class="hero__noise" aria-hidden="true"></div>

		<div class="container hero__inner">
			<div class="hero__copy reveal">
				<p class="hero__kicker">Calm. Private. No shame.</p>
				<h1>A gentler way to<br/>quit nicotine.</h1>
				<p class="hero__subline">
					{SITE_NAME} helps you reduce snus and nicotine pouches gradually — at your own pace, on your own device.
				</p>

				<div class="hero__cta">
					<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true} trackSource="hero">
						{appStoreCtaLabel}
					</Button>
					<Button variant="secondary" href="#screenshots">See the app</Button>
				</div>

				<p class="hero__fineprint">
					No accounts &middot; No usage tracking &middot; No subscriptions &middot; Your data stays on your device
				</p>
			</div>

			<div class="hero__visual reveal" aria-hidden="true">
				<div class="hero__phone-group">
					<div class="hero__phone hero__phone--back">
						<img
							src="/screenshots/v1.2/06-progress.png"
							alt=""
							width="393"
							height="852"
							loading="eager"
							decoding="async"
						/>
					</div>
					<div class="hero__phone hero__phone--front anim-float">
						<img
							src="/screenshots/v1.2/05-today.png"
							alt="Wean Nicotine app showing daily allowance tracking"
							width="393"
							height="852"
							loading="eager"
							decoding="async"
							fetchpriority="high"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ SOCIAL PROOF BAR ══ -->
	<section class="proof">
		<div class="container">
			<div class="proof__row">
				<div class="proof__item">
					<span class="proof__icon">&#9679;</span>
					<span class="proof__label">100% local &amp; private</span>
				</div>
				<div class="proof__item">
					<span class="proof__icon">&#9679;</span>
					<span class="proof__label">One-time purchase</span>
				</div>
				<div class="proof__item">
					<span class="proof__icon">&#9679;</span>
					<span class="proof__label">Works offline</span>
				</div>
				<div class="proof__item">
					<span class="proof__icon">&#9679;</span>
					<span class="proof__label">No sign-up required</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ HOW IT WORKS ══ -->
	<Section id="how" title="How it works" lede="A simple, gentle process you can stick with.">
		<div class="grid-3">
			<Card as="article">
				<h3>1) Set your baseline</h3>
				<p>Tell Wean how many pouches you use per day and your current price per can.</p>
			</Card>
			<Card as="article">
				<h3>2) Follow your allowance</h3>
				<p>Get a clear daily number and log in one tap: "Used one" or "Resisted".</p>
			</Card>
			<Card as="article">
				<h3>3) Use the tools</h3>
				<p>Leverage breathing exercises, reflection, and see your weekly savings grow.</p>
			</Card>
		</div>
	</Section>

	<!-- ══ SCREENSHOTS ══ -->
	<section id="screenshots" class="screenshots-section">
		<div class="nordic-bg" style="background-image: url('/images/unsplash/nordic-1.jpg');"></div>
		<div class="container">
			<div class="section-header reveal">
				<h2>See the app in action</h2>
				<p>Track daily use, handle cravings, and watch your progress grow — all in a calm, focused interface.</p>
			</div>
			<div class="screenshots-showcase reveal">
				<div class="screenshot-card">
					<img src="/screenshots/v1.2/05-today.png" alt="Today screen: daily allowance of 3/16 pouches with one-tap logging" width="393" height="852" loading="lazy" decoding="async" />
					<p class="screenshot-caption">Log use in one tap</p>
				</div>
				<div class="screenshot-card screenshot-card--hero">
					<img src="/screenshots/v1.2/06-progress.png" alt="Progress screen: weekly stats showing pouches avoided, money saved, and daily chart" width="393" height="852" loading="lazy" decoding="async" />
					<p class="screenshot-caption">Track your progress</p>
				</div>
				<div class="screenshot-card">
					<img src="/screenshots/v1.2/07-tools.png" alt="Support tools: breathing exercise, reflection prompts, urge surfing, and cost savings" width="393" height="852" loading="lazy" decoding="async" />
					<p class="screenshot-caption">Handle cravings</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ FEATURES ══ -->
	<Section
		id="features"
		title="Tools built for your journey"
		lede="Everything you need to reduce gradually — without accounts, shame, or noise."
	>
		<div class="grid-3">
			<Card as="article">
				<h3>Interactive Breathing</h3>
				<p>Calm your nervous system with 4-7-8, Box Breathing, or Quick Calm vibrations.</p>
			</Card>
			<Card as="article">
				<h3>Guided Urge Surfing</h3>
				<p>A 5-minute guided timer that helps you observe and 'ride' the nicotine craving.</p>
			</Card>
			<Card as="article">
				<h3>Reflection Journal</h3>
				<p>Save short notes about your triggers and progress to understand your patterns.</p>
			</Card>
			<Card as="article">
				<h3>Financial Overview</h3>
				<p>See exactly how much money you have saved since you started — right on your device.</p>
			</Card>
			<Card as="article">
				<h3>Privacy by Default</h3>
				<p>No accounts, no cloud sync, no usage tracking. Your logs and plan stay on your device.</p>
			</Card>
			<Card as="article">
				<h3>No Subscriptions</h3>
				<p>Pay once, own the app forever. No hidden fees or recurring payments.</p>
			</Card>
		</div>
	</Section>

	<!-- ══ NATURE BREAK ══ -->
	<section class="nature-break">
		<div class="nordic-bg" style="background-image: url('/images/unsplash/nordic-3.jpg');"></div>
		<div class="container nature-break__inner reveal">
			<h2>Your pace. Your privacy. Your journey.</h2>
			<p>Built by someone who gets it — no corporate agenda, no data harvesting. Just a calm tool that helps you take back control.</p>
			<div class="hero__cta" style="justify-content: center;">
				<Button variant="primary" href={APP_STORE_URL} disabled={!appStoreKnown} external={true} trackSource="midpage">
					{appStoreCtaLabel}
				</Button>
			</div>
		</div>
	</section>

	<!-- ══ FAQ ══ -->
	<Section id="faq" title="Frequently asked questions" lede="Common questions about snus reduction and nicotine pouch tracking.">
		<div class="grid-2">
			<Card as="article"><h3>{faqItems[0].question}</h3><p>{faqItems[0].answer}</p></Card>
			<Card as="article"><h3>{faqItems[1].question}</h3><p>{faqItems[1].answer}</p></Card>
			<Card as="article"><h3>{faqItems[2].question}</h3><p>{faqItems[2].answer}</p></Card>
			<Card as="article"><h3>{faqItems[3].question}</h3><p>{faqItems[3].answer}</p></Card>
			<Card as="article"><h3>{faqItems[4].question}</h3><p>{faqItems[4].answer}</p></Card>
			<Card as="article"><h3>{faqItems[5].question}</h3><p>{faqItems[5].answer}</p></Card>
			<Card as="article"><h3>{faqItems[6].question}</h3><p>{faqItems[6].answer}</p></Card>
			<Card as="article"><h3>{faqItems[7].question}</h3><p>{faqItems[7].answer}</p></Card>
		</div>
	</Section>
</Layout>

<style>
	/* ═══════════════════════════════════════
	   HERO — Animated Aurora Background
	   ═══════════════════════════════════════ */
	.hero {
		position: relative;
		padding: clamp(100px, 18vw, 200px) 0 clamp(80px, 12vw, 160px);
		min-height: clamp(600px, 85vh, 1100px);
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	/* Aurora orbs */
	.hero__aurora {
		position: absolute;
		inset: 0;
		z-index: -2;
		overflow: hidden;
	}

	.hero__aurora-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.5;
		will-change: transform;
	}

	.hero__aurora-orb--1 {
		width: clamp(400px, 50vw, 800px);
		height: clamp(400px, 50vw, 800px);
		background: var(--primary);
		top: -20%;
		left: -10%;
		animation: aurora-drift-1 16s ease-in-out infinite;
	}

	.hero__aurora-orb--2 {
		width: clamp(300px, 40vw, 600px);
		height: clamp(300px, 40vw, 600px);
		background: #8b5cf6;
		bottom: -10%;
		right: -5%;
		animation: aurora-drift-2 20s ease-in-out infinite;
	}

	.hero__aurora-orb--3 {
		width: clamp(250px, 35vw, 500px);
		height: clamp(250px, 35vw, 500px);
		background: #06b6d4;
		top: 30%;
		left: 40%;
		animation: aurora-drift-3 14s ease-in-out infinite;
	}

	@keyframes aurora-drift-1 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(10%, 15%) scale(1.1); }
		66% { transform: translate(-5%, -10%) scale(0.95); }
	}

	@keyframes aurora-drift-2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(-15%, -10%) scale(1.15); }
		66% { transform: translate(10%, 5%) scale(0.9); }
	}

	@keyframes aurora-drift-3 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(15%, -20%) scale(1.2); }
	}

	/* Noise texture overlay for depth */
	.hero__noise {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(ellipse at 50% 0%, transparent 50%, var(--bg-app) 100%),
			linear-gradient(to bottom, transparent 0%, var(--bg-app) 95%);
	}

	/* Dark mode: different orb colors */
	@media (prefers-color-scheme: dark) {
		.hero__aurora-orb--1 {
			background: var(--primary);
			opacity: 0.3;
		}
		.hero__aurora-orb--2 {
			background: #7c3aed;
			opacity: 0.25;
		}
		.hero__aurora-orb--3 {
			background: #0891b2;
			opacity: 0.2;
		}
	}

	.hero__inner {
		display: grid;
		gap: clamp(40px, 6vw, 80px);
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
	}

	.hero__kicker {
		margin: 0 0 var(--space-md);
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 13px;
	}

	h1 {
		font-size: var(--font-size-hero);
		line-height: var(--line-height-tight);
		letter-spacing: -0.04em;
	}

	.hero__subline {
		margin: var(--space-xl) 0 var(--space-xxxl);
		color: var(--text-secondary);
		font-size: clamp(18px, 2vw, 21px);
		line-height: var(--line-height-relaxed);
		max-width: 50ch;
	}

	.hero__cta {
		display: flex;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.hero__fineprint {
		margin: var(--space-xxxl) 0 0;
		color: var(--text-tertiary);
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.02em;
	}

	/* Hero phone group — overlapping phones */
	.hero__visual {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.hero__phone-group {
		position: relative;
		width: 340px;
		height: 500px;
	}

	.hero__phone {
		position: absolute;
		border-radius: var(--radius-xl);
		border: 1px solid var(--border-glass);
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(20px);
		padding: 1px;
		overflow: hidden;
		box-shadow: 0 40px 100px rgba(0, 0, 0, 0.25);
	}

	.hero__phone img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: inherit;
	}

	.hero__phone--front {
		width: 280px;
		z-index: 2;
		top: 0;
		left: 0;
	}

	.hero__phone--back {
		width: 240px;
		z-index: 1;
		top: 40px;
		right: 0;
		opacity: 0.7;
		transform: rotate(4deg);
	}

	/* ═══════════════════════════════════════
	   SOCIAL PROOF BAR
	   ═══════════════════════════════════════ */
	.proof {
		padding: var(--space-xxl) 0;
		border-bottom: 1px solid var(--border-subtle);
	}

	.proof__row {
		display: flex;
		justify-content: center;
		gap: var(--space-xxxl);
		flex-wrap: wrap;
	}

	.proof__item {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.proof__icon {
		color: var(--primary);
		font-size: 8px;
	}

	.proof__label {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--text-secondary);
	}

	/* ═══════════════════════════════════════
	   SCREENSHOTS SHOWCASE
	   ═══════════════════════════════════════ */
	.screenshots-section {
		position: relative;
		padding: var(--space-huge) 0;
		overflow: hidden;
	}

	.screenshots-showcase {
		display: grid;
		grid-template-columns: 1fr 1.15fr 1fr;
		gap: var(--space-xl);
		align-items: center;
		max-width: 900px;
		margin: 0 auto;
	}

	.screenshot-card {
		text-align: center;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.screenshot-card:hover {
		transform: translateY(-12px);
	}

	.screenshot-card--hero {
		transform: scale(1.08);
		z-index: 2;
	}

	.screenshot-card--hero:hover {
		transform: scale(1.08) translateY(-12px);
	}

	.screenshot-card img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: var(--radius-xl);
		border: 1px solid var(--border-glass);
		box-shadow: var(--shadow-premium);
	}

	.screenshot-caption {
		margin: var(--space-lg) 0 0;
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--text-secondary);
	}

	/* ═══════════════════════════════════════
	   NATURE BREAK — Mid-page CTA
	   ═══════════════════════════════════════ */
	.nature-break {
		position: relative;
		padding: clamp(80px, 12vw, 180px) 0;
		overflow: hidden;
		text-align: center;
	}

	.nature-break__inner {
		max-width: 640px;
		margin: 0 auto;
	}

	.nature-break__inner h2 {
		margin-bottom: var(--space-lg);
	}

	.nature-break__inner p {
		font-size: var(--font-size-lg);
		line-height: var(--line-height-relaxed);
		color: var(--text-secondary);
		margin-bottom: var(--space-xxl);
	}

	/* ═══════════════════════════════════════
	   RESPONSIVE
	   ═══════════════════════════════════════ */
	@media (max-width: 1100px) {
		.hero__inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.hero__copy {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.hero__subline {
			margin-left: auto;
			margin-right: auto;
		}

		.hero__cta {
			justify-content: center;
		}

		.hero__phone-group {
			margin: 0 auto;
		}
	}

	@media (max-width: 768px) {
		.screenshots-showcase {
			grid-template-columns: 1fr;
			max-width: 280px;
		}

		.screenshot-card--hero {
			transform: none;
		}

		.screenshot-card--hero:hover {
			transform: translateY(-12px);
		}

		.proof__row {
			gap: var(--space-lg);
		}

		.hero__phone-group {
			width: 280px;
			height: 420px;
		}

		.hero__phone--front {
			width: 230px;
		}

		.hero__phone--back {
			width: 200px;
		}
	}

	/* Reduce motion for accessibility */
	@media (prefers-reduced-motion: reduce) {
		.hero__aurora-orb {
			animation: none !important;
		}
		.anim-float {
			animation: none !important;
		}
	}
</style>
