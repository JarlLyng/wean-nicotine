{
  "name": "wean-nicotine",
  "main": "expo-router/entry",
  "version": "1.5.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "doctor": "expo-doctor",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,mdc,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/ios/",
      "/android/",
      "/website/",
      "/dist/"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry|native-base))",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^8",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-store-review": "~55.0.15",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "@tootallnate/once": "^3.0.1"
  },
  "private": true
}
