# Kopiér til .env og udfyld værdierne.
# .env er i .gitignore og committes ikke.

# Sentry – DSN (appen sender fejl til Sentry)
# Hent: sentry.io → dit projekt → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry – Auth Token (valgfrit, til Sentry CLI fx upload af source maps)
# Opret: sentry.io → User settings → Auth Tokens. Scopes: project:releases, org:read, project:read
# SENTRY_AUTH_TOKEN=sntrys_xxx
