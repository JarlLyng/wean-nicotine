# Kopiér til .env og udfyld værdierne.
# .env er i .gitignore og committes ikke.

# ── Sentry ──────────────────────────────────────────────
# DSN (appen sender fejl til Sentry i production)
# Hent: sentry.io → dit projekt → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx

# Auth Token (til source-map upload under build)
# Opret: sentry.io → Settings → Auth Tokens → Create New Token
# Påkrævede scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_xxx

# Org og projekt slugs (vises i URL'en: sentry.io/organizations/<org>/projects/<project>/)
SENTRY_ORG=din-org
SENTRY_PROJECT=dit-projekt
